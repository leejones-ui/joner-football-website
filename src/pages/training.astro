---
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'

const localBizSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Joner Football HQ",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 2, 20 Narabang Way",
    "addressLocality": "Belrose",
    "addressRegion": "NSW",
    "postalCode": "2085",
    "addressCountry": "AU"
  },
  "telephone": "+61-426-885-924",
  "url": "https://jonerfootball.com/hq",
  "openingHours": "Mo-Sa",
  "priceRange": "$$"
}
---

<BaseLayout
  title="Sydney Training Programs | Joner Football"
  description="Sydney football training programs at Joner Football. JFP Performance program, professional training, and Joners Juniors. Indoor facility at Belrose. Ages 8+."
  schema={localBizSchema}
>

  <!-- Hero -->
  <section class="relative min-h-[60vh] w-full flex items-center justify-center bg-joner-gray overflow-hidden">
    <div class="absolute inset-0 w-full h-full">
      <img src="/images/training/hero-bg.webp" alt="Joner Football training session at indoor facility" style="width:100%;height:100%;object-fit:cover;object-position:center;position:absolute;inset:0" />
      <div class="absolute inset-0 bg-gradient-to-b from-joner-black/70 via-joner-black/50 to-joner-black/80"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto py-24">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">Sydney, Australia</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase leading-none mb-6">
        Sydney Training<br/>Programs
      </h1>
      <p class="text-gray-300 font-body text-lg md:text-xl max-w-2xl mx-auto">
        From grassroots to professional. Train at Australia's premier football development facility.
      </p>
    </div>
  </section>

  <!-- Programs overview nav -->
  <section class="bg-joner-black border-b border-gray-800 sticky top-16 z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex overflow-x-auto gap-0 scrollbar-hide">
        <a href="#jfp" class="flex-shrink-0 px-6 py-4 text-sm font-heading uppercase tracking-wider text-gray-400 hover:text-white hover:bg-joner-gray border-b-2 border-transparent hover:border-joner-red transition-all whitespace-nowrap">JFP Program</a>
        <a href="#pro-training" class="flex-shrink-0 px-6 py-4 text-sm font-heading uppercase tracking-wider text-gray-400 hover:text-white hover:bg-joner-gray border-b-2 border-transparent hover:border-joner-red transition-all whitespace-nowrap">Professional Training</a>
        <a href="#joners-juniors" class="flex-shrink-0 px-6 py-4 text-sm font-heading uppercase tracking-wider text-gray-400 hover:text-white hover:bg-joner-gray border-b-2 border-transparent hover:border-joner-red transition-all whitespace-nowrap">Joners Juniors</a>
        <a href="#game-analysis" class="flex-shrink-0 px-6 py-4 text-sm font-heading uppercase tracking-wider text-gray-400 hover:text-white hover:bg-joner-gray border-b-2 border-transparent hover:border-joner-red transition-all whitespace-nowrap">Game Analysis</a>
      </div>
    </div>
  </section>

  <!-- ===== TRAINING HIGHLIGHT VIDEOS ===== -->
  <section class="bg-joner-black py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">See It In Action</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold text-white uppercase">Training Highlights</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- How I Coach -->
        <div>
          <div class="relative w-full" style="aspect-ratio: 16/9;">
            <iframe
              srcdoc="<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%;background:#0a0a0a}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#fff;text-shadow:0 0 0.5em black}</style><a href=https://www.youtube.com/embed/D13QAvWlZWg?autoplay=1><img src=https://img.youtube.com/vi/D13QAvWlZWg/hqdefault.jpg alt='How I Coach'><span>&#x25BA;</span></a>"
              src="https://www.youtube.com/embed/D13QAvWlZWg"
              title="How I Coach, Joner Football"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full border border-gray-800"
            ></iframe>
          </div>
          <p class="font-heading text-white text-sm uppercase tracking-wider mt-3">How I Coach</p>
        </div>

        <!-- Pro Soccer Drills -->
        <div>
          <div class="relative w-full" style="aspect-ratio: 16/9;">
            <iframe
              srcdoc="<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%;background:#0a0a0a}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#fff;text-shadow:0 0 0.5em black}</style><a href=https://www.youtube.com/embed/1a1EOdqwF54?autoplay=1><img src=https://img.youtube.com/vi/1a1EOdqwF54/hqdefault.jpg alt='Pro Soccer Drills'><span>&#x25BA;</span></a>"
              src="https://www.youtube.com/embed/1a1EOdqwF54"
              title="Pro Soccer Drills, Joner Football"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full border border-gray-800"
            ></iframe>
          </div>
          <p class="font-heading text-white text-sm uppercase tracking-wider mt-3">Pro Soccer Drills</p>
        </div>

        <!-- Passing Drill Combo -->
        <div>
          <div class="relative w-full" style="aspect-ratio: 16/9;">
            <iframe
              srcdoc="<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%;background:#0a0a0a}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#fff;text-shadow:0 0 0.5em black}</style><a href=https://www.youtube.com/embed/J8uguy9_OQ4?autoplay=1><img src=https://img.youtube.com/vi/J8uguy9_OQ4/hqdefault.jpg alt='Passing Drill Combo'><span>&#x25BA;</span></a>"
              src="https://www.youtube.com/embed/J8uguy9_OQ4"
              title="Passing Drill Combo, Joner Football"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full border border-gray-800"
            ></iframe>
          </div>
          <p class="font-heading text-white text-sm uppercase tracking-wider mt-3">Passing Drill Combo</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== JFP ===== -->
  <section id="jfp" class="bg-joner-black py-20 md:py-28 scroll-mt-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- JFP photo -->
        <div class="bg-joner-gray aspect-[4/3] lg:aspect-auto lg:min-h-[500px] border border-gray-800 order-2 lg:order-1 overflow-hidden">
          <img src="/images/training/lee-coaching-action.webp" alt="Lee Jones coaching a Joner Football Performance small group session at The HQ" class="w-full h-full object-cover object-center" loading="lazy" />
        </div>

        <!-- Content -->
        <div class="order-1 lg:order-2">
          <div class="inline-block bg-joner-red px-3 py-1 font-heading text-xs uppercase tracking-widest text-white mb-4">Flagship Program</div>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-white uppercase mb-4">
            Joner Football<br/>Performance
          </h2>
          <p class="text-joner-red font-heading text-sm uppercase tracking-wider mb-6">Running since 2013</p>
          <p class="text-gray-300 font-body leading-relaxed mb-8">
            Since its launch in 2013, the Joner Football Performance Program has been dedicated to helping players reach their full potential, both on and off the pitch. Thousands of players developed, many going on to elite youth squads, professional and international competition. Ages 8+ and all ability levels.
          </p>

          <!-- Schedule -->
          <div class="border-l-4 border-joner-red pl-6 mb-8">
            <h3 class="font-heading text-white font-semibold uppercase tracking-wide mb-3">Schedule</h3>
            <p class="text-gray-400 font-body text-sm mb-1">Monday to Saturday, term-by-term</p>
            <p class="text-gray-400 font-body text-sm mb-1">10-week terms</p>
            <p class="text-gray-400 font-body text-sm">Train up to 3 times per week</p>
          </div>

          <!-- Locations -->
          <div class="border-l-4 border-gray-700 pl-6 mb-8">
            <h3 class="font-heading text-white font-semibold uppercase tracking-wide mb-3">Locations</h3>
            <div class="space-y-2">
              <div class="flex items-start gap-2">
                <span class="text-joner-red mt-0.5 flex-shrink-0">▸</span>
                <p class="text-gray-400 font-body text-sm"><strong class="text-white">Afternoon sessions:</strong> The HQ, 20 Narabang Way, Belrose (indoor, all weather)</p>
              </div>
              <div class="flex items-start gap-2">
                <span class="text-joner-red mt-0.5 flex-shrink-0">▸</span>
                <p class="text-gray-400 font-body text-sm"><strong class="text-white">Morning sessions:</strong> North Turramurra & Rydalmere Park</p>
              </div>
            </div>
          </div>

          <!-- What makes JFP different -->
          <div class="bg-joner-gray border border-gray-700 p-6 mb-8">
            <h3 class="font-heading text-white font-semibold uppercase tracking-wide mb-4">What Makes JFP Different</h3>
            <ul class="space-y-3">
              {[
                'Max 6 players per group. Grouped by age first, then ability',
                'Individual Player Reports every term',
                'Game Analysis Service exclusive to JF players',
                'Players pushed into older groups when they dominate',
                'Professional standard coaching. Qualified, experienced team',
              ].map((point) => (
                <li class="flex items-start gap-3">
                  <span class="text-joner-red font-bold flex-shrink-0">✓</span>
                  <span class="text-gray-300 font-body text-sm">{point}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Partnerships -->
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-joner-gray border border-gray-700 px-4 py-3 text-center">
              <div class="font-heading text-white font-bold text-sm">Mizuno</div>
              <div class="text-gray-500 text-xs font-body mt-1">Official Equipment</div>
            </div>
            <div class="bg-joner-gray border border-gray-700 px-4 py-3 text-center">
              <div class="font-heading text-white font-bold text-sm">SKLZ</div>
              <div class="text-gray-500 text-xs font-body mt-1">Training Equipment</div>
            </div>
            <div class="bg-joner-gray border border-gray-700 px-4 py-3 text-center">
              <div class="font-heading text-white font-bold text-sm">FPA</div>
              <div class="text-gray-500 text-xs font-body mt-1">Strength & Conditioning</div>
            </div>
            <div class="bg-joner-gray border border-gray-700 px-4 py-3 text-center">
              <div class="font-heading text-white font-bold text-sm">FullNinety</div>
              <div class="text-gray-500 text-xs font-body mt-1">Tactical Analysis</div>
            </div>
          </div>

          <!-- Head coach -->
          <div class="border border-joner-red/30 bg-joner-red/5 p-6 mb-8">
            <h3 class="font-heading text-white font-semibold uppercase tracking-wide mb-3">Head Coach</h3>
            <div class="flex items-center gap-4">
              <div class="bg-joner-gray w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-2xl">👤</span>
              </div>
              <div>
                <div class="font-heading text-white font-bold">Dean McDonnell</div>
                <div class="text-gray-400 text-sm font-body">Head Coach, JFP</div>
                <a href="tel:0426885924" class="text-joner-red text-sm font-body hover:underline">0426 885 924</a>
              </div>
            </div>
          </div>

          <!-- FAQ -->
          <div class="mb-8">
            <h3 class="font-heading text-white font-semibold uppercase tracking-wide mb-4">FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'Will bad weather cancel the session?', a: 'No. Only extreme storms. Afternoon sessions at The HQ are fully indoor.' },
                { q: "Who will be in my child's group?", a: 'Players are grouped by age first, then ability. Max 6 per group. If a player dominates their group, we push them up to the older age group.' },
                { q: 'How many times a week can my child train?', a: 'Up to 3 times per week depending on schedule and goals.' },
              ].map((item) => (
                <div class="border-b border-gray-800 pb-4">
                  <dt class="font-heading text-white text-sm font-semibold mb-1">{item.q}</dt>
                  <dd class="text-gray-400 font-body text-sm">{item.a}</dd>
                </div>
              ))}
            </div>
          </div>

          <p class="text-gray-500 font-body text-sm italic mb-6">Dedicated players only. Limited spots available.</p>
          <a href="#jfp-form" class="btn-red text-sm">Apply Now</a>
        </div>
      </div>

      <!-- JFP Enquiry Form -->
      <div id="jfp-form" class="mt-16 max-w-2xl mx-auto bg-joner-gray border border-gray-700 p-8 scroll-mt-32">
        <h3 class="font-heading text-white text-2xl font-bold uppercase mb-2">Apply for JFP</h3>
        <p class="text-gray-400 font-body text-sm mb-6">Fill in your details and a coach will be in touch.</p>
        <form data-brevo-form data-form-name="jfp-application" data-list-id="2" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" name="parent_name" placeholder="Parent name" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="text" name="player_name" placeholder="Player name" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="email" name="email" placeholder="Email address" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="tel" name="phone" placeholder="Phone number" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" name="player_age" placeholder="Player age" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="text" name="experience" placeholder="Current club / experience level" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <textarea name="message" placeholder="Anything else we should know?" rows="3" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 resize-none"></textarea>
          <button type="submit" class="btn-red text-sm w-full">Submit Application</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== JFP PLAYER PATHWAY ===== -->
  <section class="bg-joner-gray py-20 md:py-28 overflow-hidden">
    <style>
      @keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 15px rgba(227, 6, 19, 0.3), 0 0 30px rgba(227, 6, 19, 0.1); }
        50% { box-shadow: 0 0 25px rgba(227, 6, 19, 0.5), 0 0 50px rgba(227, 6, 19, 0.2); }
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .pathway-node {
        animation: fadeUp 0.6s ease-out both;
      }
      .pathway-node:nth-child(1) { animation-delay: 0.1s; }
      .pathway-node:nth-child(2) { animation-delay: 0.3s; }
      .pathway-node:nth-child(3) { animation-delay: 0.5s; }
      .pathway-glow {
        animation: pulseGlow 3s ease-in-out infinite;
      }
      .benefit-card {
        animation: fadeUp 0.5s ease-out both;
      }
      .benefit-card:nth-child(1) { animation-delay: 0.7s; }
      .benefit-card:nth-child(2) { animation-delay: 0.8s; }
      .benefit-card:nth-child(3) { animation-delay: 0.9s; }
      .benefit-card:nth-child(4) { animation-delay: 1.0s; }
      .benefit-card:nth-child(5) { animation-delay: 1.1s; }
      .benefit-card:nth-child(6) { animation-delay: 1.2s; }
    </style>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center mb-16">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">The Journey</p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white uppercase leading-none mb-4">
          JFP Player Pathway
        </h2>
        <p class="text-gray-400 font-body text-lg max-w-2xl mx-auto">
          From first touch to professional career. Every stage is designed to develop the complete footballer.
        </p>
      </div>

      <!-- ====== PATHWAY VISUAL ====== -->
      <div class="relative">

        <!-- === STAGE 1: JONERS JUNIORS === -->
        <div class="pathway-node flex flex-col items-center mb-4">
          <div class="relative bg-joner-black border-2 border-joner-red rounded-lg p-6 md:p-8 max-w-lg w-full text-center pathway-glow">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-joner-red px-4 py-1 rounded-full">
              <span class="font-heading text-white text-xs uppercase tracking-widest">Stage 1</span>
            </div>
            <div class="text-4xl mb-3 mt-2">&#9917;</div>
            <h3 class="font-heading text-white text-xl md:text-2xl font-bold uppercase mb-2">Joners Juniors</h3>
            <p class="text-gray-400 font-body text-sm">First touch starts here. Building foundations in a fun, safe environment.</p>
          </div>
        </div>

        <!-- Connector line 1 -->
        <div class="flex justify-center mb-4">
          <div class="w-1 h-12 md:h-16 bg-gradient-to-b from-joner-red to-joner-red/60 rounded-full"></div>
        </div>
        <!-- Arrow -->
        <div class="flex justify-center mb-4">
          <div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-t-[12px] border-t-joner-red"></div>
        </div>

        <!-- === STAGE 2: 6-8 YEAR OLD PROGRAM === -->
        <div class="pathway-node flex flex-col items-center mb-4">
          <div class="relative bg-joner-black border-2 border-joner-red/70 rounded-lg p-6 md:p-8 max-w-lg w-full text-center">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-joner-red px-4 py-1 rounded-full">
              <span class="font-heading text-white text-xs uppercase tracking-widest">Stage 2</span>
            </div>
            <div class="text-4xl mb-3 mt-2">&#127947;</div>
            <h3 class="font-heading text-white text-xl md:text-2xl font-bold uppercase mb-2">Joner 6-8 Year Old Program</h3>
            <p class="text-gray-400 font-body text-sm">Structured development bridging juniors into serious training. Technique, confidence, game understanding.</p>
          </div>
        </div>

        <!-- Connector line 2 -->
        <div class="flex justify-center mb-4">
          <div class="w-1 h-12 md:h-16 bg-gradient-to-b from-joner-red/60 to-joner-red rounded-full"></div>
        </div>
        <!-- Arrow -->
        <div class="flex justify-center mb-4">
          <div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-t-[12px] border-t-joner-red"></div>
        </div>

        <!-- === STAGE 3: JFP (Central Hub) === -->
        <div class="pathway-node flex flex-col items-center mb-6">
          <div class="relative bg-joner-black border-[3px] border-joner-red rounded-xl p-8 md:p-10 max-w-xl w-full text-center pathway-glow" style="box-shadow: 0 0 40px rgba(227, 6, 19, 0.3), 0 0 80px rgba(227, 6, 19, 0.1);">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-joner-red px-5 py-1.5 rounded-full">
              <span class="font-heading text-white text-xs uppercase tracking-widest">Flagship</span>
            </div>
            <div class="text-5xl mb-3 mt-2">&#127942;</div>
            <h3 class="font-heading text-white text-2xl md:text-3xl font-bold uppercase mb-2">
              Joner Football<br/>Performance
            </h3>
            <p class="text-gray-400 font-body text-sm mb-4">The complete development program. Ages 8+ | Max 6 per group | Since 2013</p>
            <div class="flex justify-center gap-3 flex-wrap">
              <span class="bg-joner-red/20 border border-joner-red/40 text-joner-red font-heading text-xs uppercase px-3 py-1 rounded-full">10-Week Terms</span>
              <span class="bg-joner-red/20 border border-joner-red/40 text-joner-red font-heading text-xs uppercase px-3 py-1 rounded-full">Player Reports</span>
              <span class="bg-joner-red/20 border border-joner-red/40 text-joner-red font-heading text-xs uppercase px-3 py-1 rounded-full">Elite Coaching</span>
            </div>
          </div>
        </div>

        <!-- Branching connector from JFP -->
        <div class="flex justify-center mb-2">
          <div class="w-1 h-8 bg-joner-red rounded-full"></div>
        </div>
        <!-- Horizontal spread line (desktop) -->
        <div class="hidden md:flex justify-center mb-2">
          <div class="h-1 bg-joner-red rounded-full" style="width: min(90%, 800px);"></div>
        </div>
        <!-- Vertical connectors down to benefit cards (desktop) -->
        <div class="hidden md:flex justify-center mb-6" style="width: min(90%, 800px); margin-left: auto; margin-right: auto;">
          <div class="flex justify-between w-full px-4">
            <div class="w-1 h-6 bg-joner-red/60 rounded-full"></div>
            <div class="w-1 h-6 bg-joner-red/60 rounded-full"></div>
            <div class="w-1 h-6 bg-joner-red/60 rounded-full"></div>
            <div class="w-1 h-6 bg-joner-red/60 rounded-full"></div>
            <div class="w-1 h-6 bg-joner-red/60 rounded-full"></div>
            <div class="w-1 h-6 bg-joner-red/60 rounded-full"></div>
          </div>
