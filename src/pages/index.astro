---
import BaseLayout from '../layouts/BaseLayout.astro'
import WhatWeDoCarousel from '../components/WhatWeDoCarousel.astro'
import SocialProofBar from '../components/SocialProofBar.astro'
import AudienceRouter from '../components/AudienceRouter.astro'
import TechniqueTestCTA from '../components/TechniqueTestCTA.astro'
import AppShowcase from '../components/AppShowcase.astro'
import YouTubeShorts from '../components/YouTubeShorts.astro'
import CampHighlights from '../components/CampHighlights.astro'
import TestimonialCarousel from '../components/TestimonialCarousel.astro'
import EmailCapture from '../components/EmailCapture.astro'
---

<BaseLayout
  title="Joner Football | Technique Above Everything"
  description="Joner Football. Elite football coaching, 1,500+ training drills, global camps, and the world's best coaching app. Train with Coach Joner. Technique above everything."
>
  <WhatWeDoCarousel />
  <SocialProofBar />
  <AudienceRouter />
  <TechniqueTestCTA />
  <AppShowcase />
  <YouTubeShorts />
  <CampHighlights />
  <TestimonialCarousel />

  <!-- Partners Bar -->
  <section class="bg-joner-black border-t border-gray-800 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-gray-500 font-heading text-xs uppercase tracking-widest mb-6">Official Partners</p>
      <div class="flex flex-wrap justify-center items-center gap-4">
        <div class="flex flex-col items-center gap-2">
          <div class="bg-joner-black border border-white flex items-center justify-center" style="width:160px;height:80px">
            <img src="/images/partners/mizuno.png" alt="Mizuno" style="height:40px;object-fit:contain;filter:brightness(0) invert(1);" />
          </div>
          <div class="text-gray-500 text-xs font-body">Official Equipment Partner</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="bg-joner-black border border-white flex items-center justify-center" style="width:160px;height:80px">
            <img src="/images/partners/sklz.png" alt="SKLZ" style="height:40px;object-fit:contain;filter:brightness(0) invert(1);" />
          </div>
          <div class="text-gray-500 text-xs font-body">Training Equipment Partner</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="bg-joner-black border border-white flex items-center justify-center" style="width:160px;height:80px">
            <span class="font-heading text-white uppercase text-xl tracking-wider font-bold">FPA</span>
          </div>
          <div class="text-gray-500 text-xs font-body">Strength & Conditioning Partner</div>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="bg-joner-black border border-white flex items-center justify-center" style="width:160px;height:80px">
            <span class="font-heading text-white uppercase text-lg tracking-wider font-bold">Full Ninety</span>
          </div>
          <div class="text-gray-500 text-xs font-body">Tactical Analysis Partner</div>
        </div>
      </div>
    </div>
  </section>

  <EmailCapture />
</BaseLayout>
