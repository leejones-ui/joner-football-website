---
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Lee Jones & Joner Football",
  "description": "About Lee Jones and Joner Football. Voted Top 10 Technical Trainers in the World. From Sydney to global.",
  "url": "https://jonerfootball.com/about",
  "mainEntity": {
    "@type": "Person",
    "name": "Lee Jones",
    "jobTitle": "Founder & Head Coach",
    "worksFor": {
      "@type": "Organization",
      "name": "Joner Football"
    }
  }
}
---

<BaseLayout
  title="About Lee Jones & Joner Football | Joner Football"
  description="About Lee Jones and Joner Football. Voted Top 10 Technical Trainers in the World. From Sydney to global. The Joner Football story."
  schema={schema}
>

  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center justify-center bg-joner-gray overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/about/lee-coaching.webp"
        alt="Lee Jones coaching at Joner Football"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-joner-black/80 via-joner-black/60 to-joner-black/80"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto py-24">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">From Sydney to the World</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase leading-none mb-6">
        The Joner<br/>Football Story
      </h1>
      <p class="text-gray-300 font-body text-lg md:text-xl max-w-2xl mx-auto">
        From Sydney to the world. Technique above everything.
      </p>
    </div>
  </section>

  <!-- Lee's Story -->
  <section class="bg-joner-black py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Content -->
        <div>
          <div class="inline-block bg-joner-red px-3 py-1 font-heading text-xs uppercase tracking-widest text-white mb-4">The Founder</div>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-white uppercase mb-6">
            Lee 'Joner' Jones
          </h2>

          <p class="text-gray-300 font-body leading-relaxed mb-6">
            Lee Jones earned his UEFA C licence at 16 as a youth player at Wrexham AFC. By 19 he held his UEFA B licence and was appointed Academy Director at Rhyl FC Academy. He led his U14s to an international tournament win in France, taking home the best coach award in the process.
          </p>

          <p class="text-gray-300 font-body leading-relaxed mb-6">
            A qualified teacher, Lee ran a community football project for unemployed adults and ex-offenders before coaching at Llandudno FC as a player/coach. He trialled for A-League clubs including Central Coast Mariners, then founded Joner Football in Sydney, Australia. What started as individual coaching sessions has grown into a global football development brand.
          </p>

          <div class="border-l-4 border-joner-red pl-6 mb-6">
            <p class="text-white font-heading text-lg uppercase tracking-wide">
              In 2017, Lee was voted one of the Top 10 Technical Trainers in the World.
            </p>
          </div>

          <p class="text-gray-300 font-body leading-relaxed mb-6">
            Lee has coached A-League, W-League, and elite international players. He has built a social media following of over 2.1 million footballers and launched the <a href="/app" class="text-joner-red hover:underline">Joner Football App</a> with 50,000+ downloads and 1,500+ training drills. His elite <a href="/camps" class="text-joner-red hover:underline">training camps</a> run across 15+ countries, and players who have trained under his methodology have gone on to professional and international careers.
          </p>

          <p class="text-gray-300 font-body leading-relaxed mb-8">
            Today, Joner Football operates out of the brand new JFP HQ in Belrose, Sydney. A state-of-the-art indoor facility purpose-built for technical development. Lee's coaching philosophy has never changed: master the ball, and the game opens up. Every drill, every session, every camp is built around technical excellence, high intensity, and genuine player development.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-joner-gray border border-gray-700 p-4 text-center">
              <div class="font-heading text-joner-red text-2xl font-bold">Top 10</div>
              <div class="text-gray-500 text-xs font-body mt-1">World Technical Trainers</div>
            </div>
            <div class="bg-joner-gray border border-gray-700 p-4 text-center">
              <div class="font-heading text-white text-2xl font-bold">2.1M+</div>
              <div class="text-gray-500 text-xs font-body mt-1">Followers</div>
            </div>
            <div class="bg-joner-gray border border-gray-700 p-4 text-center">
              <div class="font-heading text-white text-2xl font-bold">50K+</div>
              <div class="text-gray-500 text-xs font-body mt-1">App Downloads</div>
            </div>
            <div class="bg-joner-gray border border-gray-700 p-4 text-center">
              <div class="font-heading text-white text-2xl font-bold">15+</div>
              <div class="text-gray-500 text-xs font-body mt-1">Countries</div>
            </div>
          </div>
        </div>

        <!-- Image placeholder -->
        <div class="bg-joner-gray h-96 lg:h-full min-h-96 flex items-center justify-center border border-gray-800">
          <div class="text-center p-8">
            <div class="text-6xl mb-4">⚽</div>
            <p class="text-gray-500 text-sm font-body">Lee Jones photo<br/>coming soon</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- The Coaching Team -->
  <section class="bg-joner-black py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The Team</p>
        <h2 class="section-heading text-white mb-4">Our Coaching Team</h2>
        <p class="text-gray-400 font-body max-w-3xl mx-auto text-lg leading-relaxed">
          Our team of qualified, experienced coaches deliver every session to a professional standard. Grouped by age and ability, with a maximum of 6 players per group, every player gets the attention they deserve.
        </p>
      </div>

      <!-- Team photo -->
      <div class="mb-12">
        <img
          src="/images/about/coaching-team.webp"
          alt="The Joner Football coaching team"
          class="w-full h-auto object-cover object-center border border-gray-800"
        />
      </div>

      <!-- Key differentiators -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-joner-gray border border-gray-800 p-8 text-center">
          <div class="font-heading text-joner-red text-3xl font-bold mb-2">6</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Max Per Group</h3>
          <p class="text-gray-400 text-sm font-body">Small groups, maximum attention. Every player matters.</p>
        </div>
        <div class="bg-joner-gray border border-gray-800 p-8 text-center">
          <div class="font-heading text-joner-red text-3xl font-bold mb-2">100%</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Qualified Coaches</h3>
          <p class="text-gray-400 text-sm font-body">Every coach is qualified, experienced, and committed to development.</p>
        </div>
        <div class="bg-joner-gray border border-gray-800 p-8 text-center">
          <div class="font-heading text-joner-red text-3xl font-bold mb-2">Pro</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Standard</h3>
          <p class="text-gray-400 text-sm font-body">Professional standard delivery. Every session. Every time.</p>
        </div>
      </div>

      <!-- Placeholder for additional coach profiles -->
      <div class="border border-gray-800 border-dashed p-8 text-center">
        <p class="text-gray-500 font-body text-sm">Individual coach profiles coming soon.</p>
      </div>

      <div class="text-center mt-12">
        <a href="/training" class="btn-red text-sm">View Training Programs</a>
      </div>
    </div>
  </section>

  <!-- Continue training at home CTA -->
  <section class="bg-joner-red py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading text-2xl md:text-4xl font-bold text-white uppercase mb-4">
        Continue Your Training at Home
      </h2>
      <p class="text-white/80 font-body mb-6">
        Continue your training at home with the Joner Football App. 1,500+ drills, session plans, and follow-along programs.
      </p>
      <a href="/app" class="btn-outline text-base px-8 py-4 border-white text-white hover:bg-white hover:text-joner-red">
        Explore the App
      </a>
    </div>
  </section>

  <!-- Partnerships -->
  <section class="bg-joner-gray border-y border-gray-800 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Partnerships</p>
        <h2 class="section-heading text-white">Official Partners</h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="bg-joner-black border border-gray-700 px-6 py-4 inline-block mb-2">
            <span class="font-heading text-white font-bold text-xl">Mizuno</span>
          </div>
          <p class="text-gray-500 text-xs font-body">Official Equipment Partner</p>
        </div>
        <div class="text-center">
          <div class="bg-joner-black border border-gray-700 px-6 py-4 inline-block mb-2">
            <span class="font-heading text-white font-bold text-xl">SKLZ</span>
          </div>
          <p class="text-gray-500 text-xs font-body">Training Equipment Partner</p>
        </div>
        <div class="text-center">
          <div class="bg-joner-black border border-gray-700 px-6 py-4 inline-block mb-2">
            <span class="font-heading text-white font-bold text-xl">FPA</span>
          </div>
          <p class="text-gray-500 text-xs font-body">Strength & Conditioning Partner</p>
        </div>
        <div class="text-center">
          <div class="bg-joner-black border border-gray-700 px-6 py-4 inline-block mb-2">
            <span class="font-heading text-white font-bold text-xl">FullNinety</span>
          </div>
          <p class="text-gray-500 text-xs font-body">Tactical Analysis Partner</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Forms -->
  <section id="contact" class="bg-joner-black py-20 md:py-28 scroll-mt-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Get in Touch</p>
        <h2 class="section-heading text-white">Contact Us</h2>
      </div>

      <!-- Form tabs -->
      <div class="flex flex-wrap gap-2 mb-8 justify-center">
        <button class="contact-tab px-4 py-2 font-heading text-xs uppercase tracking-wider bg-joner-red text-white" data-tab="general">General Enquiry</button>
        <button class="contact-tab px-4 py-2 font-heading text-xs uppercase tracking-wider border border-gray-700 text-gray-400 hover:border-white hover:text-white transition-colors" data-tab="training">Training Enquiry</button>
        <button class="contact-tab px-4 py-2 font-heading text-xs uppercase tracking-wider border border-gray-700 text-gray-400 hover:border-white hover:text-white transition-colors" data-tab="coaching">Coaching Application</button>
      </div>

      <!-- General Enquiry Form -->
      <div class="contact-form-panel" id="form-general">
        <form method="POST" action="https://api.brevo.com/v3/contacts" data-brevo-form data-form-name="general-enquiry" class="space-y-4 bg-joner-gray border border-gray-800 p-6 md:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" name="name" placeholder="Full name" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="email" name="email" placeholder="Email address" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <input type="tel" name="phone" placeholder="Phone number" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          <textarea name="message" placeholder="Your message" required rows="5" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 resize-none"></textarea>
          <button type="submit" class="btn-red text-sm w-full">Send Enquiry</button>
        </form>
      </div>

      <!-- Training Enquiry Form -->
      <div class="contact-form-panel hidden" id="form-training">
        <form method="POST" action="https://api.brevo.com/v3/contacts" data-brevo-form data-form-name="training-enquiry" class="space-y-4 bg-joner-gray border border-gray-800 p-6 md:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" name="name" placeholder="Full name" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="email" name="email" placeholder="Email address" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="tel" name="phone" placeholder="Phone number" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="text" name="player_age" placeholder="Player's age" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <input type="text" name="club" placeholder="Club / team (optional)" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          <textarea name="message" placeholder="Tell us about the player and what you are looking for" required rows="4" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 resize-none"></textarea>
          <button type="submit" class="btn-red text-sm w-full">Submit Training Enquiry</button>
        </form>
      </div>

      <!-- Coaching Application Form -->
      <div class="contact-form-panel hidden" id="form-coaching">
        <form method="POST" action="https://api.brevo.com/v3/contacts" data-brevo-form data-form-name="coaching-application" class="space-y-4 bg-joner-gray border border-gray-800 p-6 md:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" name="name" placeholder="Full name" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
            <input type="email" name="email" placeholder="Email address" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          </div>
          <input type="tel" name="phone" placeholder="Phone number" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          <input type="text" name="experience" placeholder="Coaching experience (years and level)" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          <input type="text" name="qualifications" placeholder="Qualifications (e.g. UEFA B, FFA C)" required class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          <textarea name="why_jf" placeholder="Why do you want to coach at Joner Football?" required rows="4" class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 resize-none"></textarea>
          <button type="submit" class="btn-red text-sm w-full">Submit Application</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.contact-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab

        // Update tab styles
        document.querySelectorAll('.contact-tab').forEach(t => {
          t.classList.remove('bg-joner-red', 'text-white')
          t.classList.add('border', 'border-gray-700', 'text-gray-400')
        })
        tab.classList.add('bg-joner-red', 'text-white')
        tab.classList.remove('border', 'border-gray-700', 'text-gray-400')

        // Show target form
        document.querySelectorAll('.contact-form-panel').forEach(p => p.classList.add('hidden'))
        document.getElementById(`form-${target}`)?.classList.remove('hidden')
      })
    })
  </script>

  <EmailCapture />

</BaseLayout>
