            Start Free Trial
          </a>
        </div>

        <!-- Plan 2: Annual (MOST POPULAR) -->
        <div class="border-2 border-joner-red p-6 flex flex-col relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-joner-red px-4 py-1 font-heading text-xs uppercase tracking-wider text-white">
            Most Popular
          </div>
          <div class="font-heading text-sm text-joner-red uppercase tracking-wider mb-2">Annual</div>
          <div class="mb-1">
            <span class="font-heading text-3xl text-white font-bold">$204.99</span>
            <span class="text-gray-500 font-body text-sm">/year</span>
          </div>
          <p class="text-green-400 text-xs font-body mb-1">7-day FREE trial</p>
          <p class="text-joner-red text-xs font-heading font-bold uppercase mb-4">Save $83/year</p>
          <ul class="space-y-2 mb-6 flex-1">
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Everything in Monthly</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">DM Lee</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Team Training</span></li>
            <li class="flex items-start gap-2"><span class="text-gray-600 flex-shrink-0 text-sm">✗</span><span class="text-gray-600 text-sm font-body">Coaches Section</span></li>
          </ul>
          <a href="https://app.jonerfootball.com/checkout/new?o=183092" class="btn-red text-sm w-full text-center block" target="_blank" rel="noopener">
            Start Free Trial
          </a>
        </div>

        <!-- Plan 3: For The Coaches -->
        <div class="border border-gray-800 p-6 flex flex-col">
