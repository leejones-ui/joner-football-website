---
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'
---
<BaseLayout title="The Joner Football App | Download Free" description="1,500+ drills, session plans, and coaching content. Download the Joner Football app free on iOS and Android.">
  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">Coming Soon</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-6">App Page</h1>
      <p class="text-gray-400 font-body mb-8">Full page in progress. Download the app at:</p>
      <a href="https://app.jonerfootball.com" class="btn-red text-base px-8 py-4">Download Free Now</a>
    </div>
  </section>
  <EmailCapture />
</BaseLayout>
