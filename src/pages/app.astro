---
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Joner Football App",
  "operatingSystem": "iOS, Android",
  "applicationCategory": "SportsApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "AUD"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "50000"
  }
}
---

<BaseLayout
  title="Joner Football App | 1,500+ Drills, Session Plans, Coaching"
  description="Download the Joner Football App. 1,500+ drills, session plans, follow-along programs, coaches section, and weekly live sessions. Free section available."
  schema={appSchema}
>

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center bg-joner-gray overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-joner-black via-gray-900 to-joner-gray opacity-90"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Text content -->
        <div class="text-center lg:text-left">
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">The App</p>
          <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold text-white uppercase leading-none mb-6">
            Your Complete<br/>Training Platform
          </h1>
          <p class="text-gray-300 font-body text-lg md:text-xl mb-8 max-w-lg">
            1,500+ drills. Session plans. Follow-along programs. Coaches section. Everything you need to take your game to the next level.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-8">
            <a href="https://app.jonerfootball.com" class="btn-red text-base px-8 py-4 text-center">
              Download Free
            </a>
            <button id="watch-video-btn" class="btn-outline text-base px-8 py-4 text-center">
              Watch How It Works
            </button>
          </div>

          <!-- Store badges -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="https://apps.apple.com/au/app/joner-football-app/id6737069275" target="_blank" rel="noopener"
              class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              <div>
                <div class="text-white text-xs leading-none">Download on the</div>
                <div class="text-white font-semibold text-sm">App Store</div>
              </div>
            </a>
            <a href="https://play.google.com/store/apps/details?id=tv.uscreen.jonerfootball" target="_blank" rel="noopener"
              class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.4.6 1.2 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/></svg>
              <div>
                <div class="text-white text-xs leading-none">Get it on</div>
                <div class="text-white font-semibold text-sm">Google Play</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Phone mockup with real screenshot -->
        <div class="flex justify-center">
          <div class="relative">
            <div class="bg-joner-black border-4 border-gray-700 rounded-3xl w-72 h-[580px] overflow-hidden shadow-2xl">
              <img src="/images/app/screenshot-1.webp" alt="Joner Football App showing drill library with 1500+ training drills" class="w-full h-full object-cover object-top" />
            </div>
            <div class="absolute -inset-4 bg-joner-red/10 rounded-3xl blur-xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof strip -->
  <section class="bg-joner-black border-y border-gray-800 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        <div>
          <div class="font-heading text-2xl text-joner-red font-bold">50,000+</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body">Downloads</div>
        </div>
        <div>
          <div class="font-heading text-2xl text-white font-bold">4.8★</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body">App Store Rating</div>
        </div>
        <div>
          <div class="font-heading text-2xl text-white font-bold">1,500+</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body">Training Drills</div>
        </div>
        <div>
          <div class="font-heading text-2xl text-white font-bold">15+</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body">Countries</div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Inside -->
  <section class="bg-joner-gray py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">What's Inside</p>
        <h2 class="section-heading text-white mb-4">Everything You Need</h2>
        <p class="text-gray-400 font-body max-w-2xl mx-auto">
          From individual drills to complete training programs. For players, coaches, and parents.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors group">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-joner-red transition-colors">1,500+ Drills</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Every technique, every position. Ball mastery, first touch, weak foot, 1v1 moves, finishing, and more. New drills added regularly.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors group">
          <div class="text-4xl mb-4">📄</div>
          <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-joner-red transition-colors">Session Plans</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Ready-to-print PDF session plans for coaches. Structured training sessions you can run straight away. Saves hours of planning.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors group">
          <div class="text-4xl mb-4">▶️</div>
          <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-joner-red transition-colors">Follow-Along Programs</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Guided video programs you train alongside Coach Joner. Set up, press play, and follow along. Like having a personal trainer.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors group">
          <div class="text-4xl mb-4">🧠</div>
          <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-joner-red transition-colors">Coaches Section</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Behind-the-scenes coaching methodology. Learn how and why Joner Football trains the way it does. Level up your coaching.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors group">
          <div class="text-4xl mb-4">📡</div>
          <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-joner-red transition-colors">Weekly Live Sessions</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Train live with Lee every week. Real-time coaching, Q&A, and community. Replays available if you miss it.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors group">
          <div class="text-4xl mb-4">👥</div>
          <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-joner-red transition-colors">Team Subscriptions</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Train your whole squad. Bulk pricing for teams and clubs. Give every player access to world-class training content.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="bg-joner-black py-20 md:py-28" id="pricing">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Pricing</p>
        <h2 class="section-heading text-white mb-4">Choose Your Plan</h2>
        <p class="text-gray-400 font-body">All paid plans include a 7-day FREE trial. Cancel anytime.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

        <!-- Plan 1: Monthly -->
        <div class="border border-gray-800 p-6 flex flex-col">
          <div class="font-heading text-sm text-gray-400 uppercase tracking-wider mb-2">Monthly</div>
          <div class="mb-4">
            <span class="font-heading text-3xl text-white font-bold">$23.99</span>
            <span class="text-gray-500 font-body text-sm">/month</span>
          </div>
          <p class="text-green-400 text-xs font-body mb-4">7-day FREE trial</p>
          <ul class="space-y-2 mb-6 flex-1">
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">1,500+ Videos</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">New Content Weekly</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Daily Challenges</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Community</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Live Sessions</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Follow-along Programs</span></li>
            <li class="flex items-start gap-2"><span class="text-joner-red flex-shrink-0 text-sm">✓</span><span class="text-gray-400 text-sm font-body">Age Specific Content</span></li>
            <li class="flex items-start gap-2"><span class="text-gray-600 flex-shrink-0 text-sm">✗</span><span class="text-gray-600 text-sm font-body">DM Lee</span></li>
            <li class="flex items-start gap-2"><span class="text-gray-600 flex-shrink-0 text-sm">✗</span><span class="text-gray-600 text-sm font-body">Team Training</span></li>
            <li class="flex items-start gap-2"><span class="text-gray-600 flex-shrink-0 text-sm">✗</span><span class="text-gray-600 text-sm font-body">Coaches Section</span></li>
