        <div class="border border-gray-800 bg-joner-gray p-6 flex flex-col">
          <div class="font-heading text-sm text-gray-400 uppercase tracking-wider mb-2">Club Subscriptions</div>
          <div class="mb-4">
            <span class="font-heading text-3xl text-white font-bold">Custom</span>
          </div>
