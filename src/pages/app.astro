---
import BaseLayout from '../layouts/BaseLayout.astro'
import PhoneFrame from '../components/PhoneFrame.astro'
import EmailCapture from '../components/EmailCapture.astro'

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Joner Football App",
  "operatingSystem": "iOS, Android",
  "applicationCategory": "SportsApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "AUD"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "50000"
  }
}
---

<BaseLayout
  title="Joner Football App | Your Complete Training Platform"
  description="The world's #1 football training app. 1,500+ drills, session plans, follow-along programs, and the 100-Day Player Programme. Try free today."
  schema={appSchema}
>

  <!-- SECTION 1: Hero -->
  <section class="relative min-h-[90vh] flex items-center bg-joner-gray overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover z-0"
      style="opacity: 0.4;"
    >
      <source src="https://res.cloudinary.com/dmzisjwdf/video/upload/v1775278435/joner-website/hero-video.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/60 z-[1]"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red z-[2]"></div>

    <div class="relative z-[2] max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Text content -->
        <div class="text-center lg:text-left">
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">THE WORLD'S #1 FOOTBALL TRAINING APP</p>
          <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold text-white uppercase leading-none mb-6">
            YOUR COMPLETE<br/>TRAINING PLATFORM
          </h1>
          <p class="text-gray-300 font-body text-lg md:text-xl mb-8 max-w-lg mx-auto lg:mx-0">
            Train like a professional footballer. From your first touch to your 1,000th session. Everything you need to transform your game. On your phone, on your terms.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-10">
            <a href="https://app.jonerfootball.com/checkout/new?o=183083" target="_blank" rel="noopener noreferrer" class="btn-red text-base px-8 py-4 text-center font-heading uppercase tracking-wider">
              START FREE TRIAL
            </a>
            <a href="https://app.jonerfootball.com/categories/category-vpi8uazway4" target="_blank" rel="noopener noreferrer" class="btn-outline text-base px-8 py-4 text-center font-heading uppercase tracking-wider">
              BROWSE FREE CONTENT
            </a>
          </div>

          <!-- App Store badges -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="https://apps.apple.com/au/app/joner-football-app/id6737069275" target="_blank" rel="noopener noreferrer"
              class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              <div>
                <div class="text-white text-xs leading-none">Download on the</div>
                <div class="text-white font-semibold text-sm">App Store</div>
              </div>
            </a>
            <a href="https://play.google.com/store/apps/details?id=tv.uscreen.jonerfootball" target="_blank" rel="noopener noreferrer"
              class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.4.6 1.2 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/></svg>
              <div>
                <div class="text-white text-xs leading-none">Get it on</div>
                <div class="text-white font-semibold text-sm">Google Play</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Phone frames with video -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <!-- Primary phone -->
            <div class="relative" style="width:270px;height:490px">
              <PhoneFrame
                images={["/images/app/screenshot-1.webp", "/images/app/screenshot-2.webp", "/images/app/screenshot-3.webp", "/images/app/screenshot-4.webp"]}
                alt="Joner Football App session plan demo"
                class="w-full h-full"
              />
            </div>
            <!-- Secondary phone (desktop only) -->
            <div class="hidden md:block absolute -right-16 top-20" style="width:210px;height:380px">
              <PhoneFrame
                images={["/images/app/screenshot-5.webp", "/images/app/screenshot-6.webp", "/images/app/screenshot-7.webp", "/images/app/screenshot-8.webp"]}
                alt="Joner Football App training drills"
                class="w-full h-full opacity-80"
              />
            </div>
            <div class="absolute -inset-4 bg-joner-red/10 rounded-3xl blur-xl -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section class="bg-joner-black border-y border-gray-800 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center items-center gap-y-6 gap-x-4 sm:gap-x-6 text-center">
        <div>
          <div class="font-heading text-3xl text-white font-bold">380,000+</div>
          <div class="text-[#999999] text-xs uppercase tracking-wider font-body mt-1">YouTube Subscribers</div>
        </div>
        <span class="hidden sm:block text-[#CC0000] text-2xl leading-none">&bull;</span>
        <div>
          <div class="font-heading text-3xl text-white font-bold">1,500+</div>
          <div class="text-[#999999] text-xs uppercase tracking-wider font-body mt-1">Drills and Sessions</div>
        </div>
        <span class="hidden sm:block text-[#CC0000] text-2xl leading-none">&bull;</span>
        <div>
          <div class="font-heading text-3xl text-white font-bold">50,000+</div>
          <div class="text-[#999999] text-xs uppercase tracking-wider font-body mt-1">Downloads</div>
        </div>
        <span class="hidden sm:block text-[#CC0000] text-2xl leading-none">&bull;</span>
        <div>
          <div class="font-heading text-3xl text-white font-bold">50+</div>
          <div class="text-[#999999] text-xs uppercase tracking-wider font-body mt-1">Countries Worldwide</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Three Audience Cards -->
  <section class="bg-joner-gray py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Players -->
        <div class="bg-joner-black border border-gray-800 p-8 md:p-10 flex flex-col">
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">PLAYERS</p>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-white uppercase mb-4">TRANSFORM YOUR GAME IN 100 DAYS</h3>
          <p class="text-gray-400 font-body text-base leading-relaxed mb-8 flex-1">
            Follow the 100-Day Player Programme. A structured, day-by-day training plan that takes you from where you are now to a technically complete footballer. No guesswork. No wasted sessions. Just daily progress you can see and feel.
          </p>
          <a href="https://jonerfootball.com/join/" class="btn-red text-center text-sm px-6 py-3">START THE 100-DAY PROGRAMME</a>
        </div>

        <!-- Coaches -->
        <div class="bg-joner-black border border-gray-800 p-8 md:p-10 flex flex-col">
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">COACHES</p>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-white uppercase mb-4">EVERY SESSION. PLANNED. DELIVERED. DONE.</h3>
          <p class="text-gray-400 font-body text-base leading-relaxed mb-8 flex-1">
            Stop spending hours building session plans from scratch. The Joner Football App gives you a complete library of ready-made sessions, drills, and progressions. Run better training for your team or small group every single week without the prep time.
          </p>
          <a href="https://app.jonerfootball.com/checkout/new?o=202578" target="_blank" rel="noopener noreferrer" class="btn-red text-center text-sm px-6 py-3">START COACHING SMARTER</a>
        </div>

        <!-- Parents -->
        <div class="bg-joner-black border border-gray-800 p-8 md:p-10 flex flex-col">
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">PARENTS</p>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-white uppercase mb-4">GIVE YOUR CHILD THE EDGE</h3>
          <p class="text-gray-400 font-body text-base leading-relaxed mb-8 flex-1">
            Your child wants to get better. The app gives them a clear path. Structured programs, daily challenges, and technique drills they can follow on their own. No more wondering what to practise. They press play and train.
          </p>
          <a href="https://jonerfootball.com/join/" class="btn-red text-center text-sm px-6 py-3">START YOUR CHILD'S JOURNEY</a>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION 3: 100-Day Programme Spotlight -->
  <section class="bg-joner-black py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: headline + body -->
        <div>
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">THE PROGRAMME</p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-white uppercase leading-tight mb-4">THE 100-DAY PLAYER PROGRAMME</h2>
          <p class="text-gray-300 font-body text-lg mb-6">Your day-by-day path to becoming a technically complete footballer.</p>
          <p class="text-gray-400 font-body text-base leading-relaxed mb-8">
            Most players train without a plan. The 100-Day Programme changes that. Every day, you get a specific session designed to build on the last. Ball mastery. First touch. Passing. Movement. By Day 100, you are a different player.
          </p>
          <a href="https://jonerfootball.com/join/" class="btn-red text-base px-8 py-4">START DAY 1 NOW</a>
        </div>

        <!-- Right: numbered steps -->
        <div class="space-y-8">
          <div class="flex gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-joner-red flex items-center justify-center font-heading text-2xl font-bold text-white">1</div>
            <div>
              <h4 class="font-heading text-lg font-bold text-white uppercase mb-2">DAYS 1 TO 30</h4>
              <p class="text-gray-400 font-body">Build your foundation. Ball mastery, first touch, close control.</p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-joner-red flex items-center justify-center font-heading text-2xl font-bold text-white">2</div>
            <div>
              <h4 class="font-heading text-lg font-bold text-white uppercase mb-2">DAYS 31 TO 70</h4>
              <p class="text-gray-400 font-body">Add complexity. Passing patterns, movement, game scenarios.</p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-joner-red flex items-center justify-center font-heading text-2xl font-bold text-white">3</div>
            <div>
              <h4 class="font-heading text-lg font-bold text-white uppercase mb-2">DAYS 71 TO 100</h4>
              <p class="text-gray-400 font-body">Put it all together. Full sessions that mirror real match demands.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- LEE GUARANTEE SECTION -->
  <section class="bg-joner-gray py-20 md:py-28 border-t-4 border-[#CC0000]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">FROM THE FOUNDER</p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-white uppercase leading-tight mb-4">MY PERSONAL GUARANTEE</h2>
          <p class="text-gray-300 font-body text-lg mb-6">I have been coaching players, coaches and parents for over 20 years. I built this app for one reason.</p>
          <p class="text-gray-400 font-body text-base leading-relaxed mb-8">
            Whether you are a player trying to reach the next level, a coach who wants to run better sessions, or a parent wanting to give your child every possible advantage. I guarantee this app will make a difference. Follow the programs. Do the work. If you are not improving within 100 days, I will extend your membership for free. That is how confident I am.
          </p>
          <div class="mb-8">
            <p class="font-heading text-2xl text-white italic">Lee Jones</p>
            <p class="text-[#999999] text-xs uppercase tracking-widest font-heading mt-1">Founder, Joner Football</p>
          </div>
          <a href="https://jonerfootball.com/join/" class="btn-red text-base px-8 py-4">START MY 100-DAY JOURNEY</a>
        </div>
        <div class="flex justify-center lg:justify-end">
          <img
            src="/images/programmes/lee-coaching-red.jpg"
            alt="Lee Jones coaching on the pitch"
            class="w-full max-w-md rounded-lg shadow-2xl"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Feature Showcase -->
  <section class="bg-joner-gray py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading text-white mb-4">EVERYTHING YOU NEED. NOTHING YOU DON'T.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors">
          <h3 class="font-heading text-xl font-bold text-white mb-3">1,500+ DRILLS AND SESSIONS</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">Every drill filmed, explained, and organised by skill level. From beginner to elite.</p>
        </div>

        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors">
          <h3 class="font-heading text-xl font-bold text-white mb-3">SESSION PLANS</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">Complete session plans ready to run. Perfect for coaches who want quality without the prep.</p>
        </div>

        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors">
          <h3 class="font-heading text-xl font-bold text-white mb-3">FOLLOW-ALONG PROGRAMS</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">Press play and train. Programs that guide you through every rep, every set, every session.</p>
        </div>

        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors">
          <h3 class="font-heading text-xl font-bold text-white mb-3">DAILY CHALLENGES</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">A new challenge every day. Track your progress. Build consistency.</p>
        </div>

        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors">
          <h3 class="font-heading text-xl font-bold text-white mb-3">COACHES SECTION</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">Dedicated coaching library. Session plans, progressions, and small group formats.</p>
        </div>

        <div class="bg-joner-black border border-gray-800 p-8 hover:border-joner-red transition-colors">
          <h3 class="font-heading text-xl font-bold text-white mb-3">OFFLINE DOWNLOADS</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">Download sessions to your phone. Train anywhere, even without wifi.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INSIDE THE APP: Screenshots -->
  <section class="bg-joner-black py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">INSIDE THE APP</p>
        <h2 class="section-heading text-white">EVERYTHING ORGANISED. EVERYTHING READY.</h2>
      </div>

      <div class="flex gap-6 overflow-x-auto pb-4 md:grid md:grid-cols-4 md:gap-8 md:overflow-visible md:pb-0 scrollbar-hide">
        {[
          { src: '/images/app/screenshot-1.webp', label: 'Drill Library' },
          { src: '/images/app/screenshot-3.webp', label: 'Session Plans' },
          { src: '/images/app/screenshot-5.webp', label: 'Programme View' },
          { src: '/images/app/screenshot-7.webp', label: 'Daily Training' },
        ].map((item) => (
          <div class="flex-shrink-0 w-56 md:w-auto text-center">
            <div class="bg-gray-900 border-[5px] border-gray-700 rounded-[2rem] overflow-hidden shadow-2xl">
              <img src={item.src} alt={item.label} class="w-full h-auto" loading="lazy" />
            </div>
            <p class="text-[#999999] text-xs uppercase tracking-widest font-heading mt-4">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 5: Coaches Deep Dive -->
  <section class="bg-joner-black py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">FOR COACHES</p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white uppercase leading-tight mb-4">BUILT FOR COACHES. NOT JUST PLAYERS.</h2>
        <p class="text-gray-300 font-body text-lg mb-4">Transform your team sessions. Save hours every week.</p>
        <p class="text-gray-400 font-body text-base leading-relaxed">
          Whether you coach a junior team, run a small group, or manage an academy, the app gives you a professional-level session library you can use immediately. Browse by topic, age group, or session type. Select a session. Run it. Done.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="border-l-4 border-joner-red pl-6">
          <h4 class="font-heading text-lg font-bold text-white uppercase mb-2">READY-MADE SESSIONS</h4>
          <p class="text-gray-400 font-body text-sm">Stop building from scratch. Pick a session and deliver it tonight.</p>
        </div>
        <div class="border-l-4 border-joner-red pl-6">
          <h4 class="font-heading text-lg font-bold text-white uppercase mb-2">ORGANISED BY TOPIC</h4>
          <p class="text-gray-400 font-body text-sm">Passing, dribbling, finishing, possession, defensive shape. Find what you need in seconds.</p>
        </div>
        <div class="border-l-4 border-joner-red pl-6">
          <h4 class="font-heading text-lg font-bold text-white uppercase mb-2">SMALL GROUP FORMATS</h4>
          <p class="text-gray-400 font-body text-sm">Sessions designed for 4 to 12 players. Perfect for private coaching.</p>
        </div>
      </div>

      <a href="https://app.jonerfootball.com/checkout/new?o=202578" target="_blank" rel="noopener noreferrer" class="btn-red text-base px-8 py-4">EXPLORE THE COACHES PLAN</a>
    </div>
  </section>

  <!-- SECTION 6: Testimonials -->
  <section class="bg-joner-gray py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">TESTIMONIALS</p>
        <h2 class="section-heading text-white">REAL RESULTS FROM REAL USERS</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="border border-gray-700 p-8">
          <div class="text-joner-red text-4xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">
            The session plans alone are worth the subscription. Changed how I run my academy. My players are improving faster than ever.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">Coach Dave R.</div>
            <div class="text-joner-red text-xs font-heading uppercase tracking-wide">Academy Coach</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">California, USA</div>
          </div>
        </div>

        <div class="border border-gray-700 p-8">
          <div class="text-joner-red text-4xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">
            My son uses this every day. The follow-along programs are perfect. He can train independently and actually enjoys it.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">Michelle T.</div>
            <div class="text-joner-red text-xs font-heading uppercase tracking-wide">Parent</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">Sydney, Australia</div>
          </div>
        </div>

        <div class="border border-gray-700 p-8">
          <div class="text-joner-red text-4xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">
            Joner's drills are different to anything else out there. Technical, detailed, and you can feel the improvement immediately.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">James K.</div>
            <div class="text-joner-red text-xs font-heading uppercase tracking-wide">Player</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">Melbourne, Australia</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LEE COACHING IMAGES -->
  <section class="bg-joner-black py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading text-white">TRUSTED BY PLAYERS AND COACHES WORLDWIDE</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          '/images/programmes/lee-coaching-black.jpg',
