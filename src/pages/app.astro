              <tr class="border-b border-gray-800/50"><td class="py-3 pr-4 text-gray-300">New Content Weekly</td><td class="text-center py-3 px-3 text-joner-red">✓</td><td class="text-center py-3 px-3 text-joner-red">✓</td><td class="text-center py-3 px-3 text-joner-red">✓</td></tr>
              <tr class="border-b border-gray-800/50"><td class="py-3 pr-4 text-gray-300">Daily Challenges</td><td class="text-center py-3 px-3 text-joner-red">✓</td><td class="text-center py-3 px-3 text-joner-red">✓</td><td class="text-center py-3 px-3 text-joner-red">✓</td></tr>
              <tr class="border-b border-gray-800/50"><td class="py-3 pr-4 text-gray-300">Community</td><td class="text-center py-3 px-3 text-joner-red">✓</td><td class="text-center py-3 px-3 text-joner-red">✓</td><td class="text-center py-3 px-3 text-joner-red">✓</td></tr>
