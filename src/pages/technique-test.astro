---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Joner Technique Test | How Good Are You?" description="Take the free Joner Football technique test. Find out where you rank.">
  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4">
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-4">Technique Test</h1>
      <p class="text-gray-400 font-body mb-8">Find out where you rank. Free.</p>
      <a href="https://is.gd/jonertechtest" target="_blank" class="btn-red text-sm px-6 py-3">Take the Test</a>
    </div>
  </section>
</BaseLayout>
