---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Joner Technique Test | How Good Are You?" description="Take the free Joner Football technique test. Find out where your technique ranks among footballers worldwide.">

  <!-- EMAIL GATE SECTION -->
  <section id="gate" class="relative min-h-[500px] flex items-center justify-center py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/training/lee-coaching-action.webp" alt="Joner Football training" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0" style="background:rgba(0,0,0,0.7)"></div>
    </div>
    <div class="relative z-10 max-w-xl mx-auto text-center px-4">
      <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl font-bold text-white uppercase mb-4 leading-tight">
        THE JONER FOOTBALL TECHNIQUE TEST
      </h1>
      <p class="text-gray-400 font-body text-lg md:text-xl mb-10">
        Find out where your technique ranks. Enter your details to take the test.
      </p>
      <form id="gate-form" data-brevo-form data-form-name="technique-test-gate" data-list-id="2" class="max-w-md mx-auto space-y-4">
        <input
          type="text"
          name="name"
          placeholder="Your Name"
          required
          class="w-full px-5 py-3 bg-white/10 border border-gray-700 rounded text-white font-body text-base placeholder-gray-500 focus:outline-none focus:border-[#E30613] transition-colors min-h-[44px]"
        />
        <input
          type="email"
          name="email"
          placeholder="Your Email"
          required
          class="w-full px-5 py-3 bg-white/10 border border-gray-700 rounded text-white font-body text-base placeholder-gray-500 focus:outline-none focus:border-[#E30613] transition-colors min-h-[44px]"
        />
        <button type="submit" class="btn-red w-full text-sm px-6 py-3 font-heading uppercase tracking-wider">
          Take the Test
        </button>
      </form>
    </div>
  </section>

  <!-- TEST SECTION (hidden initially) -->
  <section id="test-section" class="bg-joner-black py-12 px-4 transition-opacity duration-700 ease-in-out" style="display:none; opacity:0;">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white uppercase text-center mb-8">
        Your Technique Test
      </h2>
      <div class="w-full bg-white rounded-lg overflow-hidden">
        <iframe
          id="test-iframe"
          src="https://is.gd/jonertechtest"
          title="Joner Football Technique Test"
          class="w-full border-0"
          style="height: 800px; min-height: 600px;"
          loading="lazy"
          allow="fullscreen"
        ></iframe>
      </div>
      <p class="text-gray-500 font-body text-sm text-center mt-4">
        If the test doesn't load,
        <a href="https://is.gd/jonertechtest" target="_blank" rel="noopener noreferrer" class="text-[#E30613] underline hover:text-red-400 transition-colors">
          click here to open it directly
        </a>.
      </p>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section id="cta-section" class="bg-joner-black py-20 px-4" style="display:none; opacity:0;">
    <div class="max-w-3xl mx-auto text-center transition-opacity duration-700 ease-in-out">
      <h2 class="font-heading text-3xl md:text-5xl font-bold text-white uppercase mb-4">
        Want to improve your technique?
      </h2>
      <p class="text-gray-400 font-body text-lg mb-10">
        Take your game to the next level with Joner Football.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://jonerfootball.com/join/" class="btn-red text-sm px-8 py-3 font-heading uppercase tracking-wider">
          Try the World's #1 Football App Free
        </a>
        <a href="/training" class="btn-outline text-sm px-8 py-3 font-heading uppercase tracking-wider">
          Train in Sydney
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var gate = document.getElementById('gate');
      var form = document.getElementById('gate-form');
      var testSection = document.getElementById('test-section');
      var ctaSection = document.getElementById('cta-section');

      // Mark as custom-handled so the shared Brevo handler skips it
      form.setAttribute('data-brevo-custom', 'true');

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        e.stopImmediatePropagation();

        var name = form.querySelector('input[name="name"]').value.trim();
        var email = form.querySelector('input[name="email"]').value.trim();

        if (!name || !email) return;

        // Build submission data
        var data = {
          name: name,
          email: email,
          _form: 'technique-test-gate',
          _page: window.location.pathname,
          _submitted: new Date().toISOString()
        };

        // Store in localStorage as backup
        try {
          localStorage.setItem('joner_tech_test_name', name);
          localStorage.setItem('joner_tech_test_email', email);
          var stored = JSON.parse(localStorage.getItem('brevo_submissions') || '[]');
          stored.push(data);
          localStorage.setItem('brevo_submissions', JSON.stringify(stored));
        } catch (err) {
          // localStorage not available, continue anyway
        }

        // Submit to Brevo via API route (fire-and-forget, don't block the UX)
        try {
          fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: data.email, firstName: data.name, listId: 2 })
          });
        } catch (err) {
          // Submission stored in localStorage as backup
        }

        // Hide the gate
        gate.style.transition = 'opacity 0.5s ease';
        gate.style.opacity = '0';

        setTimeout(function () {
          gate.style.display = 'none';

          // Show the test section
          testSection.style.display = 'block';
          // Force reflow before transition
          testSection.offsetHeight;
          testSection.style.opacity = '1';

          // Show the CTA section
          ctaSection.style.display = 'block';
          ctaSection.offsetHeight;
          ctaSection.style.opacity = '1';

          // Scroll to top of test
          testSection.scrollIntoView({ behavior: 'smooth' });
        }, 500);
      });
    });
  </script>

</BaseLayout>
