---
import BaseLayout from '../layouts/BaseLayout.astro'

const url = new URL(Astro.request.url)
const isEmbed = url.searchParams.get('embed') === 'true'

const cards = [
  {
    title: 'Technique Test',
    description: 'Test your technical ability. Get your score.',
    icon: '🎯',
    link: '/technique-test',
    color: 'border-red-600',
    badge: 'Free',
  },
  {
    title: 'Weekly Challenge',
    description: 'New challenge every week. Film it. Share it. Win prizes.',
    icon: '🏆',
    link: 'https://app.jonerfootball.com',
    color: 'border-white',
    badge: 'App',
  },
  {
    title: 'Football Quiz',
    description: 'Test your football knowledge. Weekly quiz in the app.',
    icon: '🧠',
    link: 'https://app.jonerfootball.com',
    color: 'border-red-600',
    badge: 'App',
  },
  {
    title: 'Free Drill of the Week',
    description: 'One free drill every week. No account needed.',
    icon: '⚽',
    link: 'https://app.jonerfootball.com',
    color: 'border-white',
    badge: 'Free',
  },
  {
    title: 'Latest Blog',
    description: 'Training tips, coaching insights, and football culture.',
    icon: '📝',
    link: '/blog',
    color: 'border-white',
  },
  {
    title: 'Ask Lee',
    description: 'Submit your question. Lee answers in the app.',
    icon: '💬',
    link: 'https://app.jonerfootball.com',
    color: 'border-red-600',
    badge: 'App',
  },
  {
    title: 'Camp Announcements',
    description: 'Upcoming camps, new locations, early bird access.',
    icon: '📣',
    link: '/camps',
    color: 'border-red-600',
  },
  {
    title: 'New on App',
    description: 'Latest drills, programs, and content added this week.',
    icon: '🆕',
    link: 'https://app.jonerfootball.com',
    color: 'border-white',
    badge: 'App',
  },
  {
    title: 'Latest Drop',
    description: 'New Joner Apparel and gear releases.',
    icon: '🔥',
    link: '/shop',
    color: 'border-red-600',
  },
]
---

{isEmbed ? (
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Joner Football Hub</title>
      <link rel="icon" type="image/x-icon" href="/favicon.ico" />
      <link rel="stylesheet" href="/src/styles/global.css" />
    </head>
    <body class="bg-joner-black text-white">
      <main class="min-h-screen">
        <Fragment set:html={`<!-- Hub Content (Embed Mode) -->`} />
        <!-- Hub header -->
        <div class="px-4 pt-8 pb-4 text-center">
          <h1 class="font-heading text-3xl font-bold text-white uppercase tracking-tight mb-2">Joner Football Hub</h1>
          <p class="text-gray-400 font-body text-sm">Everything Joner Football. All in one place.</p>
        </div>

        <!-- Card grid -->
        <div class="px-4 pb-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
            {cards.map((card) => (
              <a href={card.link} class={`block border-l-4 ${card.color} bg-[#111111] p-5 hover:bg-[#1a1a1a] transition-colors group`} target={card.link.startsWith('http') ? '_blank' : undefined} rel={card.link.startsWith('http') ? 'noopener' : undefined}>
                <div class="flex items-start gap-4">
                  <span class="text-3xl flex-shrink-0">{card.icon}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <h2 class="font-heading text-white font-bold uppercase text-sm tracking-wide group-hover:text-joner-red transition-colors">{card.title}</h2>
                      {card.badge && (
                        <span class={`font-heading text-[10px] uppercase tracking-wider px-1.5 py-0.5 ${card.badge === 'Free' ? 'bg-green-600/20 text-green-400' : 'bg-joner-red/20 text-joner-red'}`}>{card.badge}</span>
                      )}
                    </div>
                    <p class="text-gray-400 font-body text-xs leading-relaxed">{card.description}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Email capture -->
        <div class="bg-[#111111] border-t border-gray-800 px-4 py-10">
          <div class="max-w-md mx-auto text-center">
            <h2 class="font-heading text-xl font-bold text-white uppercase mb-2">Stay in the Loop</h2>
            <p class="text-gray-400 font-body text-sm mb-6">Get 10 free training videos and weekly updates from Coach Joner.</p>
            <form data-brevo-form data-form-name="hub-email-capture" data-list-id="2" class="flex flex-col sm:flex-row gap-3">
              <input type="email" name="email" placeholder="Your email" required class="flex-1 bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
              <button type="submit" class="btn-red text-sm px-6 min-h-[44px]">Subscribe</button>
            </form>

            <!-- App badges -->
            <div class="flex justify-center gap-4 mt-8">
              <a href="https://apps.apple.com/au/app/joner-football-app/id6737069275" target="_blank" rel="noopener" class="bg-black border border-gray-700 rounded-lg px-3 py-2 flex items-center gap-2 hover:border-white transition-colors">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <div>
                  <div class="text-white text-[9px] leading-none">Download on the</div>
                  <div class="text-white font-semibold text-xs">App Store</div>
                </div>
              </a>
              <a href="https://play.google.com/store/apps/details?id=tv.uscreen.jonerfootball" target="_blank" rel="noopener" class="bg-black border border-gray-700 rounded-lg px-3 py-2 flex items-center gap-2 hover:border-white transition-colors">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.4.6 1.2 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/></svg>
                <div>
                  <div class="text-white text-[9px] leading-none">Get it on</div>
                  <div class="text-white font-semibold text-xs">Google Play</div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </main>

      <!-- Brevo form handler (inline for embed) -->
      <script is:inline>
        (function () {
          document.querySelectorAll('[data-brevo-form]').forEach(function (form) {
            form.addEventListener('submit', function (e) {
              e.preventDefault();
              var btn = form.querySelector('button[type="submit"]');
              var formData = new FormData(form);
              var data = {};
              formData.forEach(function (v, k) { data[k] = v; });
              data._form = form.getAttribute('data-form-name') || 'hub';
              data._submitted = new Date().toISOString();
              try { var s = JSON.parse(localStorage.getItem('brevo_submissions') || '[]'); s.push(data); localStorage.setItem('brevo_submissions', JSON.stringify(s)); } catch(e){}
              btn.disabled = true; btn.textContent = 'Sending...';
              var email = formData.get('email') || '';
              var firstName = formData.get('first_name') || '';
              var listId = form.getAttribute('data-list-id') || '2';
              fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email, firstName: firstName, listId: Number(listId) }) })
                .then(function(r) { return r.json(); })
                .then(function(d) { form.innerHTML = '<p class="text-green-400 font-heading text-sm uppercase py-2">Subscribed. Welcome to the team.</p>'; })
                .catch(function() { form.innerHTML = '<p class="text-red-400 font-heading text-sm uppercase py-2">Something went wrong. Please try again.</p>'; });
            });
          });
        })();
      </script>
    </body>
  </html>
) : (
  <BaseLayout
    title="Hub | Joner Football"
    description="The Joner Football Hub. Technique tests, weekly challenges, free drills, blog, camp announcements, and everything Joner Football in one place."
  >
    <!-- Hub header -->
    <section class="bg-joner-black pt-16 pb-8">
      <div class="max-w-5xl mx-auto px-4 text-center">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The Hub</p>
        <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase leading-none mb-4">
          Joner Football<br/>Hub
        </h1>
        <p class="text-gray-400 font-body text-lg max-w-xl mx-auto">
          Everything Joner Football. All in one place.
        </p>
      </div>
    </section>

    <!-- Card grid -->
    <section class="bg-joner-black py-8 md:py-12">
      <div class="max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cards.map((card) => (
            <a href={card.link} class={`block border-l-4 ${card.color} bg-[#111111] p-6 hover:bg-[#1a1a1a] transition-colors group`} target={card.link.startsWith('http') ? '_blank' : undefined} rel={card.link.startsWith('http') ? 'noopener' : undefined}>
              <div class="flex items-start gap-4">
                <span class="text-3xl flex-shrink-0">{card.icon}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h2 class="font-heading text-white font-bold uppercase text-sm tracking-wide group-hover:text-joner-red transition-colors">{card.title}</h2>
                    {card.badge && (
                      <span class={`font-heading text-[10px] uppercase tracking-wider px-1.5 py-0.5 ${card.badge === 'Free' ? 'bg-green-600/20 text-green-400' : 'bg-joner-red/20 text-joner-red'}`}>{card.badge}</span>
                    )}
                  </div>
                  <p class="text-gray-400 font-body text-sm leading-relaxed">{card.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Email capture + App badges -->
    <section class="bg-[#111111] border-t border-gray-800 py-16">
      <div class="max-w-md mx-auto px-4 text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-white uppercase mb-3">Stay in the Loop</h2>
        <p class="text-gray-400 font-body text-sm mb-8">Get 10 free training videos and weekly updates from Coach Joner.</p>
        <form data-brevo-form data-form-name="hub-email-capture" data-list-id="2" class="flex flex-col sm:flex-row gap-3 mb-10">
          <input type="email" name="email" placeholder="Your email" required class="flex-1 bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]" />
          <button type="submit" class="btn-red text-sm px-6 min-h-[44px]">Subscribe</button>
        </form>

        <!-- App badges -->
        <div class="flex justify-center gap-4">
          <a href="https://apps.apple.com/au/app/joner-football-app/id6737069275" target="_blank" rel="noopener" class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div>
              <div class="text-white text-xs leading-none">Download on the</div>
              <div class="text-white font-semibold text-sm">App Store</div>
            </div>
          </a>
          <a href="https://play.google.com/store/apps/details?id=tv.uscreen.jonerfootball" target="_blank" rel="noopener" class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.4.6 1.2 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/></svg>
            <div>
              <div class="text-white text-xs leading-none">Get it on</div>
              <div class="text-white font-semibold text-sm">Google Play</div>
            </div>
          </a>
        </div>
      </div>
    </section>
  </BaseLayout>
)}
