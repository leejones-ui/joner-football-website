---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Shop | Joner Football" description="Joner Football apparel, training resources, and more.">
  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4">
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-4">Shop</h1>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="https://apparel.jonerfootball.com" target="_blank" class="btn-red text-sm px-6 py-3">Joner Apparel</a>
        <a href="/app" class="btn-outline text-sm px-6 py-3">Training App</a>
      </div>
    </div>
  </section>
</BaseLayout>
