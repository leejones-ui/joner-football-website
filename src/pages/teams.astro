---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Team & Club Subscriptions | Joner Football App" description="Bulk app subscriptions for teams and clubs. Train your whole squad.">
  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4">
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-4">Train Your Whole Squad</h1>
      <p class="text-gray-400 font-body mb-8 max-w-lg mx-auto">Team and club subscriptions for the Joner Football App. Custom pricing for your squad size.</p>
      <a href="mailto:info@jonerfootball.com?subject=Team Subscription Enquiry" class="btn-red text-sm px-6 py-3">Get a Quote</a>
    </div>
  </section>
</BaseLayout>
