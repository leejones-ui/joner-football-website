---
import BaseLayout from '../../layouts/BaseLayout.astro'
---
<BaseLayout title="Workshops | Joner Football" description="Online Coaches Course and Mindset Seminars from Joner Football.">
  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4">
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-6">Workshops</h1>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/workshops/coaches-course" class="btn-red text-sm px-6 py-3">Online Coaches Course</a>
        <a href="/workshops/mindset-seminars" class="btn-outline text-sm px-6 py-3">Mindset Seminars</a>
      </div>
    </div>
  </section>
</BaseLayout>
