---
import BaseLayout from '../../layouts/BaseLayout.astro'
import EmailCapture from '../../components/EmailCapture.astro'

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Online Coaches Course - Joner Football",
  "description": "Application-based online coaching course teaching the Joner Football methodology. Learn session planning, technical development, player assessment, and how to build a coaching business.",
  "provider": {
    "@type": "Organization",
    "name": "Joner Football",
    "url": "https://jonerfootball.com"
  },
  "url": "https://jonerfootball.com/workshops/coaches-course",
  "courseMode": "online",
  "isAccessibleForFree": false
}
---

<BaseLayout
  title="Online Coaches Course | Joner Football"
  description="Level up your coaching with the Joner Football methodology. Self-paced video modules, session plans, certificate of completion, and direct access to Lee Jones."
  schema={courseSchema}
>

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center bg-joner-gray overflow-hidden">
    <img
      src="/images/coaching-session.webp"
      alt="Joner Football coaching session"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-joner-black/80"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto py-24">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">Workshop</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase leading-none mb-6">
        Online Coaches<br/>Course
      </h1>
      <p class="text-gray-300 font-body text-lg md:text-xl max-w-2xl mx-auto mb-8">
        Level up your coaching with Joner Football's proven methodology
      </p>
      <a href="#apply" class="btn-red text-sm inline-block">Apply Now</a>
    </div>
  </section>

  <!-- What You'll Learn -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Course Content</p>
        <h2 class="section-heading text-white">What You'll Learn</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Joner Football Coaching Methodology',
            text: 'Understand the philosophy and framework behind Joner Football. Learn why technique-first coaching produces better players and how to apply this approach in every session.',
          },
          {
            title: 'Session Planning and Structure',
            text: 'Master the art of building sessions that flow, challenge players at the right level, and deliver measurable progress week after week.',
          },
          {
            title: 'Technical Development for All Ages',
            text: 'Learn how to develop technical skills across every age group, from young beginners through to senior players, with age-appropriate progressions and coaching cues.',
          },
          {
            title: 'Player Assessment and Feedback',
            text: 'Develop the ability to assess individual players, identify areas for improvement, and deliver feedback that builds confidence while driving growth.',
          },
          {
            title: 'Creating a Professional Environment',
            text: 'Set up a coaching environment where players are focused, engaged, and constantly improving. Learn how standards and expectations shape development.',
          },
          {
            title: 'Building a Coaching Business',
            text: 'Go beyond the pitch. Learn the practical steps to market your sessions, attract and retain players, and turn coaching into a sustainable career.',
          },
        ].map((item) => (
          <div class="border border-gray-800 p-6 hover:border-joner-red transition-colors">
            <div class="w-10 h-1 bg-joner-red mb-4"></div>
            <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-3">{item.title}</h3>
            <p class="text-gray-400 text-sm font-body leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="bg-joner-gray py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Who It's For</p>
          <h2 class="section-heading text-white mb-6">Built for Coaches Ready to Grow</h2>
          <p class="text-gray-300 font-body leading-relaxed mb-8">
            Whether you are just starting out or have years of experience, this course gives you a proven framework to take your coaching to the next level.
          </p>

          <ul class="space-y-4">
            {[
              'Grassroots coaches wanting to improve their sessions and develop better players',
              'Academy coaches looking for new methods and a fresh technical approach',
              'Parents who coach their kids\' teams and want to do it the right way',
              'Aspiring full-time coaches building the skills and knowledge to go professional',
            ].map((point) => (
              <li class="flex items-start gap-3">
                <span class="text-joner-red font-bold flex-shrink-0 mt-0.5">&#9658;</span>
                <span class="text-gray-300 font-body text-sm">{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="relative">
          <img
            src="/images/coaches-course-preview.webp"
            alt="Coaches working through a Joner Football training session"
            class="w-full h-80 object-cover border border-gray-800"
            loading="lazy"
          />
          <div class="absolute bottom-0 left-0 right-0 h-1 bg-joner-red"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">What's Included</p>
        <h2 class="section-heading text-white">Everything You Need</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Video Modules (Self-Paced)',
            text: 'Work through the full video course library at your own speed. Revisit any module whenever you need a refresher.',
          },
          {
            title: 'PDF Session Plans and Templates',
            text: 'Download ready-to-use session plans and planning templates built around the Joner Football methodology.',
          },
          {
            title: 'Coaches Section on the App',
            text: 'Get full access to the Coaches Section on the Joner Football App, packed with drills, session ideas, and coaching resources.',
          },
          {
            title: 'Certificate of Completion',
            text: 'Receive an official Joner Football certificate when you finish the course to add to your coaching credentials.',
          },
          {
            title: 'Direct Q&A with Lee Jones',
            text: 'Ask questions and get personalised feedback directly from Lee Jones throughout your learning journey.',
          },
          {
            title: 'Community Access',
            text: 'Join a private community of like-minded coaches. Share ideas, ask questions, and grow alongside other graduates.',
          },
        ].map((item) => (
          <div class="text-center p-6 border border-gray-800 hover:border-joner-red transition-colors">
            <div class="w-10 h-1 bg-joner-red mx-auto mb-4"></div>
            <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-3 text-sm">{item.title}</h3>
            <p class="text-gray-400 text-sm font-body leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-joner-gray py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">What Coaches Say</p>
        <h2 class="section-heading text-white">From the Coaches Who Have Done It</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="border border-gray-700 p-8">
          <div class="w-10 h-1 bg-joner-red mb-6"></div>
          <p class="text-gray-300 font-body leading-relaxed italic mb-6">
            "This course completely changed how I plan and deliver my sessions. The methodology is clear and practical. Within weeks, my players were more engaged and their technique improved noticeably. Best investment I have made in my coaching."
          </p>
          <div>
            <div class="font-heading text-white font-bold text-sm">James T.</div>
            <div class="text-gray-500 text-xs font-body">Grassroots Coach, Manchester, UK</div>
          </div>
        </div>

        <div class="border border-gray-700 p-8">
          <div class="w-10 h-1 bg-joner-red mb-6"></div>
          <p class="text-gray-300 font-body leading-relaxed italic mb-6">
            "I have been coaching at academy level for six years and this gave me a whole new framework to work with. The session planning module and the player assessment sections were brilliant. I recommend it to every serious coach I know."
          </p>
          <div>
            <div class="font-heading text-white font-bold text-sm">Matt R.</div>
            <div class="text-gray-500 text-xs font-body">Academy Coach, Sydney, Australia</div>
          </div>
        </div>

        <div class="border border-gray-700 p-8">
          <div class="w-10 h-1 bg-joner-red mb-6"></div>
          <p class="text-gray-300 font-body leading-relaxed italic mb-6">
            "I started coaching my son's team with no real experience. This course gave me the confidence and the tools to run proper sessions. The templates alone saved me hours every week. I finally feel like I know what I am doing on the pitch."
          </p>
          <div>
            <div class="font-heading text-white font-bold text-sm">Sarah K.</div>
            <div class="text-gray-500 text-xs font-body">Parent Coach, Dublin, Ireland</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Application Form -->
  <section id="apply" class="bg-joner-black py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-joner-gray border border-gray-700 p-8 md:p-10">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold uppercase mb-2">Apply Now</h2>
        <p class="text-gray-400 font-body text-sm mb-8">This course is application only. Fill in your details and we will be in touch.</p>

        <form method="POST" action="https://api.brevo.com/v3/contacts" data-brevo-form data-form-name="coaches-course-application" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input
              type="text"
              name="full_name"
              placeholder="Full name"
              required
              class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500"
            />
            <input
              type="email"
              name="email"
              placeholder="Email address"
              required
              class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500"
            />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input
              type="tel"
              name="phone"
              placeholder="Phone number"
              class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500"
            />
            <select
              name="coaching_experience"
              required
              class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm w-full focus:outline-none focus:border-joner-red appearance-none"
            >
              <option value="" disabled selected class="text-gray-500">Coaching experience</option>
              <option value="none">None</option>
              <option value="1-2 years">1-2 years</option>
              <option value="3-5 years">3-5 years</option>
              <option value="5+ years">5+ years</option>
            </select>
          </div>
          <input
            type="text"
            name="current_role"
            placeholder="Current coaching role"
            class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500"
          />
          <textarea
            name="why_join"
            placeholder="Why do you want to join this course?"
            rows="4"
            required
            class="bg-joner-black border border-gray-700 text-white px-4 py-3 font-body text-sm w-full focus:outline-none focus:border-joner-red placeholder-gray-500 resize-none"
          ></textarea>
          <button type="submit" class="btn-red text-sm w-full">Submit Application</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="bg-joner-gray py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <a href="/app" class="border border-gray-700 hover:border-joner-red p-6 transition-colors group block">
          <p class="text-joner-red font-heading text-xs uppercase tracking-widest mb-2">The App</p>
          <h3 class="font-heading text-white font-bold uppercase group-hover:text-joner-red transition-colors mb-2">Joner Football App</h3>
          <p class="text-gray-400 font-body text-sm">1,500+ drills, session plans, and the Coaches Section.</p>
        </a>
        <a href="/training" class="border border-gray-700 hover:border-joner-red p-6 transition-colors group block">
          <p class="text-joner-red font-heading text-xs uppercase tracking-widest mb-2">Training</p>
          <h3 class="font-heading text-white font-bold uppercase group-hover:text-joner-red transition-colors mb-2">Sydney Training Programs</h3>
          <p class="text-gray-400 font-body text-sm">JFP, Professional Training, and Joners Juniors in Sydney.</p>
        </a>
      </div>
    </div>
  </section>

  <EmailCapture />

</BaseLayout>
