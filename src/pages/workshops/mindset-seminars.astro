  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4">
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-4">Mindset Seminars</h1>
      <p class="text-gray-400 font-body mb-8 max-w-lg mx-auto">Mental performance workshops for players and coaches. Full details coming soon.</p>
      <a href="mailto:info@jonerfootball.com?subject=Mindset Seminar Enquiry" class="btn-red text-sm px-6 py-3">Register Interest</a>
    </div>
  </section>
</BaseLayout>
