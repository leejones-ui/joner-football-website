---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Privacy Policy | Joner Football" description="Joner Football privacy policy.">
  <section class="min-h-screen bg-joner-black py-24">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="font-heading text-4xl font-bold text-white uppercase mb-8">Privacy Policy</h1>
      <p class="text-gray-400 font-body mb-12">Full privacy policy coming soon. For enquiries: <a href="mailto:info@jonerfootball.com" class="text-joner-red hover:underline">info@jonerfootball.com</a></p>

      <h2 id="cookies" class="font-heading text-2xl font-bold text-white uppercase mb-4 scroll-mt-32">Cookie Policy</h2>
      <p class="text-gray-400 font-body">Full cookie policy coming soon. For enquiries: <a href="mailto:info@jonerfootball.com" class="text-joner-red hover:underline">info@jonerfootball.com</a></p>
    </div>
  </section>
</BaseLayout>
