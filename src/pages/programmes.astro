---
import BaseLayout from '../layouts/BaseLayout.astro'

const checkoutUrl = 'https://app.jonerfootball.com/checkout/new?o=183092&utm_source=website&utm_medium=programs_page'

const programSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Joner Football 100-Day Development Program",
  "description": "Structured football training programs followed by thousands of players in 15+ countries. Real results in 100 days, guaranteed.",
  "provider": {
    "@type": "Organization",
    "name": "Joner Football",
    "url": "https://jonerfootball.com"
  }
}

const programs = [
  { name: 'Juggling Program', days: '2 days', sessions: '', desc: 'Build your foundation. Ball feel, coordination, and touch.', num: 1, image: '/images/programmes/juggling-program.jpg' },
  { name: 'Fast Feet Program', days: '7 days', sessions: '7 sessions', desc: 'Quick feet that leave defenders guessing.', num: 2, image: '/images/programmes/fast-feet-program.jpg' },
  { name: 'Passing & First Touch Program', days: '50 days', sessions: '13 sessions', desc: 'The foundation of everything. Control under pressure. Crisp passing.', num: 3, image: '/images/programmes/passing-first-touch-program.jpg' },
  { name: 'Dribbling Program', days: '10 days', sessions: '8 sessions', desc: 'Beat any defender. Close control and changes of direction.', num: 4, image: '/images/programmes/dribbling-program.jpg' },
  { name: 'Weak Foot Program', days: '14 days', sessions: '11 sessions', desc: 'Double your options on the pitch.', num: 5, image: '/images/programmes/weak-foot-program.jpg' },
  { name: 'Score More Goals Program', days: '14 days', sessions: '9 sessions', desc: 'Turn chances into goals. Finishing technique and composure.', num: 6, image: '/images/programmes/score-more-goals-program.jpg' },
]

const steps = [
  { title: 'Choose Your Starting Point', desc: 'Begin with Juggling. Two days to build your foundation.' },
  { title: 'Follow The Plan', desc: 'Each session is short, focused, clearly demonstrated. Press play and train.' },
  { title: 'Rest and Recover', desc: 'Rest days are built in. Progress requires recovery.' },
  { title: 'Move Through The Pathway', desc: 'Complete each program before moving to the next. 100 days. One complete footballer.' },
]

const appFeatures = [
  '1,500+ training videos',
  'New content every week',
  'Daily challenges',
  'Live training sessions',
  'Age-specific content',
  'DM Lee directly (Annual only)',
  'Team training videos (Annual only)',
  'Offline downloads',
  'Streaks and progress tracking',
]

const faqs = [
  { q: 'What ages and levels is this for?', a: 'The programs work for players of all ages and levels. Whether you are 10 or 30, just starting out or playing at a high level, the structured pathway meets you where you are and builds from there.' },
  { q: 'How long are the sessions?', a: '20-30 minutes. Designed to fit around work, school, and team training.' },
  { q: 'Do I need any equipment?', a: 'Each program will clearly tell you what you need to complete it. Everything is based around minimal equipment.' },
  { q: 'What if I already train with a team?', a: 'This is individual development. The extra work that separates good players from great ones. It complements team training, it does not replace it.' },
  { q: 'How does the 100-day guarantee work?', a: 'Annual members only. Follow the program for 100 days. If you do not see improvement, we give you an extra 100 days free and you can DM Lee directly inside the app.' },
  { q: 'Are the programs available on monthly?', a: 'The structured 100-day pathway and the guarantee are exclusive to Annual members. Monthly members access the 1,500+ video library. Upgrade to Annual to access the programs.' },
  { q: 'What currency is pricing in?', a: 'All prices are in Australian Dollars (AUD).' },
  { q: 'What about the S&C program?', a: 'The 12-Week Advanced Strength and Conditioning Program is included with Annual membership. Designed for older players ready to take their physical development seriously.' },
]
---

<BaseLayout
  title="100-Day Football Program | Joner Football"
  description="Structured football training programs followed by thousands of players in 15+ countries. 6 programs, 100 days, guaranteed results. For players of all ages and levels."
  schema={programSchema}
>

  <!-- SECTION 1: HERO -->


  <section class="relative flex items-center bg-joner-gray overflow-hidden min-h-[600px]">
    <div class="absolute inset-0">
      <img src="/images/programmes/lee-hero-jf.jpg" alt="Lee Joner coaching" class="w-full h-full object-cover opacity-60" style="object-position: 70% center;" />
      <div class="absolute inset-0 bg-gradient-to-b from-joner-black/80 via-joner-black/70 to-joner-black"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full text-center">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">100-Day Development Program</p>
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white uppercase leading-tight mb-6">
        While Other Kids Watch YouTube Highlights, Yours Will Be Creating Them.
      </h1>
      <p class="text-gray-300 font-body text-lg md:text-xl mb-8 max-w-2xl mx-auto">
        100 Days From Now, Your Child Will Be Unrecognisable On The Pitch
      </p>
      <a href={checkoutUrl} class="btn-red text-base md:text-lg px-10 py-4 text-center">
        Start the Program Now
      </a>
    </div>
  </section>

  <!-- SECTION 2: THE 100-DAY PATHWAY -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The System</p>
        <h2 class="section-heading text-white mb-4">The Complete 100-Day Development Plan</h2>
        <p class="text-gray-400 font-body max-w-2xl mx-auto">
          Six structured programs. Done in order. Every day planned. Every skill built on the last. Rest days built in between. This is what transforms a player.
        </p>
      </div>

      <!-- Vertical timeline -->
      <div class="relative">
        <!-- Connecting line -->
        <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-0.5 bg-gray-800 md:-translate-x-px"></div>

        {programs.map((prog, i) => (
          <div class="relative flex items-start mb-10 last:mb-0">
            <!-- Number badge -->
            <div class="relative z-10 flex-shrink-0 w-12 h-12 bg-joner-red rounded-full flex items-center justify-center md:absolute md:left-1/2 md:-translate-x-1/2">
              <span class="font-heading text-white text-lg font-bold">{prog.num}</span>
            </div>
            <!-- Content card -->
            <div class={`ml-6 md:ml-0 md:w-[calc(50%-2rem)] bg-joner-gray border border-gray-800 p-6 ${i % 2 === 0 ? 'md:mr-auto md:pr-6' : 'md:ml-auto md:pl-6'}`}>
              <div class="flex items-center gap-3 mb-2">
                <h3 class="font-heading text-lg text-white font-bold uppercase">{prog.name}</h3>
                <span class="text-joner-red font-heading text-xs uppercase tracking-wider whitespace-nowrap">{prog.days}{prog.sessions ? ` · ${prog.sessions}` : ''}</span>
              </div>
              <p class="text-gray-400 font-body text-sm mb-4">{prog.desc}</p>
              <div style="display:inline-block;border-radius:1.5rem;border:3px solid #333;overflow:hidden;box-shadow:0 0 0 5px #1a1a1a,0 15px 30px rgba(0,0,0,0.6);margin:0 auto;margin-top:0.5rem;">
                <img src={prog.image} alt={prog.name} loading="lazy" style="display:block;width:140px;height:auto;" />
              </div>
            </div>
          </div>
        ))}

        <!-- Total badge -->
        <div class="relative z-10 mt-10 text-center">
          <div class="inline-block bg-joner-gray border-2 border-joner-red px-6 py-4">
            <p class="font-heading text-white text-lg uppercase font-bold">100 Days of Training</p>
            <p class="text-gray-400 font-body text-sm mt-1">With rest days built in between every program.</p>
          </div>
        </div>
      </div>

      <!-- BONUS -->
      <div class="mt-14 border-2 border-yellow-500/40 bg-joner-gray p-8 relative">
        <div class="absolute -top-4 left-6">
          <span class="bg-yellow-500 text-joner-black font-heading text-xs uppercase tracking-wider font-bold px-3 py-1">Bonus</span>
        </div>
        <h3 class="font-heading text-xl text-white uppercase font-bold mb-2 mt-2">12-Week Advanced Strength & Conditioning Program</h3>
        <p class="text-joner-red font-heading text-xs uppercase tracking-wider mb-3">12 weeks · 36 sessions</p>
        <p class="text-gray-400 font-body text-sm leading-relaxed mb-4">
          For older players ready to take their physical game to the next level. Football-specific speed, strength, and stamina. Start this alongside or after your 100-day journey. Annual members only.
        </p>
        <div style="display:inline-block;border-radius:1.5rem;border:3px solid #333;overflow:hidden;box-shadow:0 0 0 5px #1a1a1a,0 15px 30px rgba(0,0,0,0.6);margin:0 auto;margin-top:0.5rem;">
          <img src="/images/programmes/sc-program.jpg" alt="Strength & Conditioning Program" loading="lazy" />
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-14">
        <a href={checkoutUrl} class="btn-red w-full sm:w-auto text-base md:text-lg px-10 py-4 text-center inline-block">
          Start the Program Now
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 3: THE PROBLEM -->
  <section class="bg-joner-gray py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The Reality</p>
        <h2 class="section-heading text-white">Team Training Is Not Enough</h2>
      </div>
      <div class="text-gray-300 font-body text-base md:text-lg leading-relaxed space-y-4">
        <p>You train once or twice a week with your team. But so does every other player.</p>
        <p>The players who stand out, the ones who get picked, who make the squad, who catch the coach's eye, they do extra work. Individual work. Structured work.</p>
        <p>But what should you actually be doing? Random YouTube drills? The same thing every day? Hoping for the best?</p>
        <p class="text-white font-semibold">You need a plan. A proper program designed by a professional coach. That is exactly what this is.</p>
      </div>
      <!-- CTA -->
      <div class="text-center mt-10">
        <a href={checkoutUrl} class="btn-red w-full sm:w-auto text-base md:text-lg px-10 py-4 text-center inline-block">
          Start the Program Now
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 4: HOW IT WORKS -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">How It Works</p>
        <h2 class="section-heading text-white">Simple. Structured. It Just Works.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map((step, i) => (
          <div class="bg-joner-gray border border-gray-800 p-6 text-center">
            <div class="w-10 h-10 bg-joner-red rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="font-heading text-white text-lg font-bold">{i + 1}</span>
            </div>
            <h3 class="font-heading text-base text-white font-bold uppercase mb-2">{step.title}</h3>
            <p class="text-gray-400 font-body text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
      <!-- CTA -->
      <div class="text-center mt-10">
        <a href={checkoutUrl} class="btn-red w-full sm:w-auto text-base md:text-lg px-10 py-4 text-center inline-block">
          Start the Program Now
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 5: WHAT MAKES THIS DIFFERENT -->
  <section class="bg-joner-gray py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The Difference</p>
        <h2 class="section-heading text-white">This Is Not Just Another Training App</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-joner-black border border-gray-800 p-8">
          <h3 class="font-heading text-lg text-white font-bold uppercase mb-3">Random Drills vs. Structured Pathway</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            YouTube gives random drills with no context. This is a 100-day system with progressive difficulty.
          </p>
        </div>
        <div class="bg-joner-black border border-gray-800 p-8">
          <h3 class="font-heading text-lg text-white font-bold uppercase mb-3">Watching vs. Doing</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            Every session is designed to be done, not just watched. 20-30 minutes, a ball, a small space.
          </p>
        </div>
        <div class="bg-joner-black border border-gray-800 p-8">
          <h3 class="font-heading text-lg text-white font-bold uppercase mb-3">Hope vs. Guarantee</h3>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
            We do not just hope it works. We guarantee it. 100 days. Annual members only.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: WHATS IN THE APP -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Full Access</p>
        <h2 class="section-heading text-white">Plus Everything Else Inside The App</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {appFeatures.map((feature) => (
          <div class="bg-joner-gray border border-gray-800 px-6 py-4 flex items-center gap-3">
            <span class="text-joner-red text-lg">&#10003;</span>
            <span class="text-white font-body text-sm">{feature}</span>
          </div>
        ))}
      </div>
      <!-- App library screenshot -->
      <div class="flex justify-center mt-12">
        <div style="display:inline-block;border-radius:1.5rem;border:3px solid #333;overflow:hidden;box-shadow:0 0 0 5px #1a1a1a,0 15px 30px rgba(0,0,0,0.6);">
          <img src="/images/programmes/programmes-category.jpg" alt="Joner Football App program library" loading="lazy" style="width:160px;height:auto;border-radius:1rem;margin:0 auto;display:block;" />
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 7: SOCIAL PROOF -->
  <section class="bg-joner-gray border-y border-gray-800 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Global Community</p>
        <h2 class="section-heading text-white">Trusted By Players In 15+ Countries</h2>
        <img src="/images/programmes/lee-coaching-group.jpg" alt="Lee Joner coaching players" class="mt-8 w-full max-w-2xl mx-auto rounded-lg object-cover h-64 md:h-80" />
      </div>

      <div class="grid grid-cols-3 gap-3 sm:gap-6 text-center mb-14">
        <div>
          <div class="font-heading text-2xl sm:text-3xl md:text-4xl text-joner-red font-bold">50,000+</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body mt-1">Players</div>
        </div>
        <div>
          <div class="font-heading text-2xl sm:text-3xl md:text-4xl text-white font-bold">15+</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body mt-1">Countries</div>
        </div>
        <div>
          <div class="font-heading text-2xl sm:text-3xl md:text-4xl text-white font-bold">1,500+</div>
          <div class="text-gray-500 text-xs uppercase tracking-wider font-body mt-1">Videos</div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- ADD TESTIMONIAL HERE: Name, result, quote -->
        <div class="border border-gray-700 p-8">
          <div class="text-joner-red text-4xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">
            The 6 Week Passing &amp; 1st Touch Program completely changed my game.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">Ben Garrard</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">USA</div>
          </div>
        </div>
        <div class="border border-gray-700 p-8">
          <div class="text-joner-red text-4xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">
            The Fast Feet Program was so easy to follow, no equipment needed and I saw a huge improvement.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">Jeff Jones</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">England</div>
          </div>
        </div>
        <div class="border border-gray-700 p-8">
          <div class="text-joner-red text-4xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">
            You are the best Joner. Always trying to add and improve an already amazing brand. Hats off to you and the team.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">Henry Santos</div>
            <div class="text-joner-red text-xs font-heading uppercase tracking-wide">Coach</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">USA</div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-10">
        <a href={checkoutUrl} class="btn-red w-full sm:w-auto text-base md:text-lg px-10 py-4 text-center inline-block">
          Start the Program Now
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 8: THE GUARANTEE -->
  <section class="bg-gray-950 py-16 md:py-24 border-y border-gray-800">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The Guarantee</p>
        <h2 class="section-heading text-white">My 100-Day Promise To You</h2>
      </div>
      <div class="text-gray-300 font-body text-base md:text-lg leading-relaxed space-y-4 max-w-2xl mx-auto">
        <p>I have coached thousands of players across 15+ countries. I have spent years building these programs. I know they work.</p>
        <p>So here is my promise: commit to the full 100-day program. Follow the plan. Do the sessions.</p>
        <p>If you do not see real, visible improvement in your game, I will give you an extra 100 days FREE. And you can DM me directly inside the app with your progress and I will personally review it with you.</p>
        <p class="text-white font-semibold">That is how much I believe in this.</p>
      </div>
      <div class="mt-8 flex flex-col sm:flex-row items-center gap-6">
        <img src="/images/programmes/lee-coaching-black.jpg" alt="Lee Joner" class="w-24 h-24 rounded-full object-cover border-2 border-joner-red flex-shrink-0" style="object-position: center 20%;" />
        <div>
          <p class="font-heading text-white text-xl uppercase tracking-wider">Lee</p>
          <p class="text-gray-400 font-body text-sm">Founder, Joner Football</p>
          <p class="text-gray-600 font-body text-xs mt-2">100-Day Guarantee applies to Annual plan members only.</p>
        </div>
      </div>
      <!-- CTA -->
      <div class="text-center mt-10">
        <a href={checkoutUrl} class="btn-red w-full sm:w-auto text-base md:text-lg px-10 py-4 text-center inline-block">
          Start the Program Now
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 9: PRICING -->
  <section class="bg-joner-gray py-16 md:py-24">
    <div class="max-w-lg mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Get Started</p>
        <h2 class="section-heading text-white">One Plan. Everything Included.</h2>
      </div>

      <div class="bg-joner-black border-2 border-joner-red p-8 md:p-10">
        <div class="text-center mb-6">
          <h3 class="font-heading text-2xl text-white uppercase font-bold mb-1">Annual Plan</h3>
          <div class="font-heading text-4xl text-joner-red font-bold">$204.99</div>
          <p class="text-gray-500 font-body text-sm">AUD/year</p>
        </div>

        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>Full 100-day structured program pathway
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>All 6 training programs
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>BONUS: 12-Week Advanced S&C Program
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>100-Day Improvement Guarantee
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>1,500+ training videos
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>DM Lee directly
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>Team training videos
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>New content every week
          </li>
          <li class="flex items-start gap-3 text-gray-300 font-body text-sm">
            <span class="text-joner-red mt-0.5">&#10003;</span>Daily challenges and live sessions
          </li>
        </ul>

