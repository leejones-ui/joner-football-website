        <a href={checkoutUrl} class="btn-red w-full text-center block py-4 text-sm md:text-base">
          Start the Program Now
        </a>
        <p class="text-gray-400 font-body text-xs text-center mt-4">
          Already on Monthly? Upgrade to Annual in the app settings to unlock the full program pathway.
        </p>
        <p class="text-gray-600 font-body text-xs text-center mt-2">
          Want to see all plan options? Visit <a href="https://jonerfootball.com/join/" class="text-joner-red hover:underline">jonerfootball.com/join</a>
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 10: EMAIL CAPTURE -->
  <section class="bg-joner-black py-16 md:py-20">
    <div class="max-w-xl mx-auto px-4 sm:px-6">
      <div class="bg-joner-gray border border-joner-red/30 p-8 md:p-10">
        <div class="border-l-4 border-joner-red pl-6 mb-8">
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-white uppercase mb-3">Still Not Sold?</h2>
          <p class="text-gray-400 font-body text-sm leading-relaxed">
