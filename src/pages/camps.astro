---
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'

const campSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Joner Football Camp — LA Complete Player Experience",
    "startDate": "2026-06-22",
    "endDate": "2026-06-24",
    "location": {
      "@type": "Place",
      "name": "Gol Soccer Complex",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "North Hollywood",
        "addressRegion": "CA",
        "addressCountry": "US"
      }
    },
    "organizer": { "@type": "Organization", "name": "Joner Football" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Joner Football Camp — Houston",
    "startDate": "2026-06",
    "location": {
      "@type": "Place",
      "name": "Houston, Texas",
      "address": { "@type": "PostalAddress", "addressLocality": "Houston", "addressRegion": "TX", "addressCountry": "US" }
    },
    "organizer": { "@type": "Organization", "name": "Joner Football" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Joner Football Camp — Dallas",
    "startDate": "2026-06",
    "location": {
      "@type": "Place",
      "name": "Dallas, Texas",
      "address": { "@type": "PostalAddress", "addressLocality": "Dallas", "addressRegion": "TX", "addressCountry": "US" }
    },
    "organizer": { "@type": "Organization", "name": "Joner Football" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Joner Football Camp — Sydney ft M Grande",
    "startDate": "2026-07",
    "location": {
      "@type": "Place",
      "name": "Sydney, Australia",
      "address": { "@type": "PostalAddress", "addressLocality": "Sydney", "addressRegion": "NSW", "addressCountry": "AU" }
    },
    "organizer": { "@type": "Organization", "name": "Joner Football" }
  }
]

const camps = [
  {
    city: 'Los Angeles',
    state: 'California',
    country: 'USA',
    flag: '🇺🇸',
    dates: 'June 22-24, 2026',
    ages: 'Ages 13-18 (ECNL/MLS Next)',
    price: 'By acceptance only',
    spots: 'The Complete Player Experience',
    venue: 'Gol Soccer Complex, North Hollywood',
    href: '#la-apply',
    region: 'usa',
    featured: true,
  },
  {
    city: 'Houston',
    state: 'Texas',
    country: 'USA',
    flag: '🇺🇸',
    dates: 'June 2026',
    ages: 'Ages 8-18',
    price: 'Pricing TBC',
    spots: 'Coming soon',
    href: '#camps-notify',
    region: 'usa',
    image: '/images/camps/houston-camp.webp',
  },
  {
    city: 'Dallas',
    state: 'Texas',
    country: 'USA',
    flag: '🇺🇸',
    dates: 'June/July 2026',
    ages: 'Ages 8-18',
    price: 'Pricing TBC',
    spots: 'Coming soon',
    href: '#camps-notify',
    region: 'usa',
    image: '/images/camps/dallas-camp.webp',
  },
  {
    city: 'Sydney',
    state: 'NSW',
    country: 'Australia',
    flag: '🇦🇺',
    dates: 'July 2026 ft M Grande',
    ages: 'Ages 8-18',
    price: 'AUD pricing TBC',
    spots: 'Coming soon',
    href: '#camps-notify',
    region: 'australia',
    image: '/images/camps/sydney-camp.webp',
  },
]
---

<BaseLayout
  title="Football Camps Worldwide | Joner Football"
  description="Joner Football elite training camps in USA, Australia, and worldwide. Limited spots. Ages 8-18. Book now for 2026 camps in California, Texas, and Sydney."
  schema={campSchemas}
>

  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center justify-center bg-joner-gray overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/camps/hero-bg.webp" alt="Joner Football elite training camp group photo" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-joner-black/70 via-joner-black/50 to-joner-black/80"></div>
    </div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto py-24">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">Global Training Camps</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase leading-none mb-6">
        World Recognised<br/>Camps
      </h1>
      <p class="text-gray-300 font-body text-lg md:text-xl max-w-2xl mx-auto">
        Training camps across the globe. Train with Coach Joner and the Joner Football methodology. Limited spots available.
      </p>
    </div>
  </section>

  <!-- Filter bar (placeholder - would need JS for functionality) -->
  <section class="bg-joner-black border-b border-gray-800 sticky top-16 z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-wrap gap-3 justify-center">
        <button class="px-4 py-2 bg-joner-red text-white font-heading text-xs uppercase tracking-wider">All Camps</button>
        <button class="px-4 py-2 border border-gray-700 text-gray-400 font-heading text-xs uppercase tracking-wider hover:border-white hover:text-white transition-colors">USA</button>
        <button class="px-4 py-2 border border-gray-700 text-gray-400 font-heading text-xs uppercase tracking-wider hover:border-white hover:text-white transition-colors">Australia</button>
        <button class="px-4 py-2 border border-gray-700 text-gray-400 font-heading text-xs uppercase tracking-wider hover:border-white hover:text-white transition-colors">2026</button>
      </div>
    </div>
  </section>

  <!-- Camp cards grid -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Featured camp (LA Complete Player) -->
      <div id="la-apply" class="mb-12 scroll-mt-32">
        <p class="text-joner-red font-heading text-xs uppercase tracking-widest mb-4 text-center">Featured</p>
        <div class="border-2 border-joner-red bg-joner-gray p-6 md:p-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <div class="bg-joner-black h-64 overflow-hidden">
              <img src="/images/camps/la-camp.webp" alt="Joner Football LA Complete Player Experience camp in North Hollywood" class="w-full h-full object-cover object-center" loading="lazy" />
            </div>
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="bg-joner-red px-3 py-1 font-heading text-xs uppercase tracking-widest text-white">Elite Level</span>
                <span class="text-gray-500 font-body text-sm">June 22-24, 2026</span>
              </div>
              <h2 class="font-heading text-3xl md:text-4xl font-bold text-white uppercase mb-2">The Complete Player Experience</h2>
              <p class="text-joner-red font-heading text-sm uppercase tracking-wider mb-4">Gol Soccer Complex, North Hollywood, CA</p>
              <p class="text-gray-400 font-body mb-6">
                An elite 3-day immersive training experience for serious players aged 13-18. ECNL and MLS Next level. By acceptance only.
              </p>
              <div class="flex flex-wrap gap-4 mb-6">
                <div class="text-center">
                  <div class="font-heading text-white font-bold">Ages 13-18</div>
                  <div class="text-gray-500 text-xs font-body">ECNL / MLS Next</div>
                </div>
                <div class="text-center">
                  <div class="font-heading text-white font-bold">3 Days</div>
                  <div class="text-gray-500 text-xs font-body">Intensive</div>
                </div>
                <div class="text-center">
                  <div class="font-heading text-white font-bold">Acceptance Only</div>
                  <div class="text-gray-500 text-xs font-body">Application required</div>
                </div>
              </div>
              <a href="#la-apply" class="btn-red text-sm">Apply Now</a>
            </div>
          </div>
        </div>
      </div>

      <!-- All camps grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {camps.filter(c => !c.featured).map((camp) => (
          <div class="border border-gray-800 hover:border-joner-red transition-colors group">
            <!-- Camp image -->
            <div class="bg-joner-gray h-48 overflow-hidden relative">
              <img src={camp.image} alt={`Joner Football training camp in ${camp.city}, ${camp.state}`} class="w-full h-full object-cover object-center" loading="lazy" />
              <div class="absolute top-3 left-3 text-2xl">{camp.flag}</div>
              {camp.spots === 'Coming soon' && (
                <div class="absolute top-3 right-3 bg-gray-800/80 px-2 py-1 font-heading text-xs uppercase tracking-wider text-white">
                  Coming Soon
                </div>
              )}
            </div>
            <!-- Content -->
            <div class="p-6">
              <div class="text-xs text-joner-red font-heading uppercase tracking-wider mb-2">{camp.dates}</div>
              <h3 class="font-heading text-xl font-bold text-white mb-1 group-hover:text-joner-red transition-colors">
                {camp.city}, {camp.state}
              </h3>
              <p class="text-gray-500 text-sm font-body mb-1">{camp.ages}</p>
              <p class="text-gray-400 text-sm font-body font-semibold mb-4">{camp.price}</p>
              <a href={camp.href} class="btn-red text-sm w-full text-center block">
                {camp.spots === 'Coming soon' ? 'Register Interest' : 'Book Now'}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="bg-joner-gray py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">At Every Camp</p>
        <h2 class="section-heading text-white">What to Expect</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-6">
          <div class="text-4xl mb-4">⚽</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Elite Training</h3>
          <p class="text-gray-400 text-sm font-body">World-class coaching methodology. Technical focus. Individual attention.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">👨‍🏫</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Coach Joner</h3>
          <p class="text-gray-400 text-sm font-body">Train directly with Lee Jones. Hands-on coaching. Personal feedback.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">📊</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Small Groups</h3>
          <p class="text-gray-400 text-sm font-body">Limited numbers. Grouped by age and ability. Maximum development.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🎁</div>
          <h3 class="font-heading text-white font-bold uppercase tracking-wide mb-2">Camp Kit</h3>
          <p class="text-gray-400 text-sm font-body">Joner Football training kit included. Professional experience.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Camp highlight videos -->
  <section class="bg-joner-black py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Camp Highlights</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold text-white uppercase">See Our Camps</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <div class="relative w-full" style="aspect-ratio: 16/9;">
            <iframe
              srcdoc="<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%;background:#0a0a0a}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#fff;text-shadow:0 0 0.5em black}</style><a href=https://www.youtube.com/embed/P-qQj2J_-mE?autoplay=1><img src=https://img.youtube.com/vi/P-qQj2J_-mE/hqdefault.jpg alt='Joner Football Camp Highlight 1'><span>&#x25BA;</span></a>"
              src="https://www.youtube.com/embed/P-qQj2J_-mE"
              title="Joner Football Camp Highlight"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full border border-gray-800"
            ></iframe>
          </div>
        </div>
        <div>
          <div class="relative w-full" style="aspect-ratio: 16/9;">
            <iframe
              srcdoc="<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%;background:#0a0a0a}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#fff;text-shadow:0 0 0.5em black}</style><a href=https://www.youtube.com/embed/ZEAlkFIzVQc?autoplay=1><img src=https://img.youtube.com/vi/ZEAlkFIzVQc/hqdefault.jpg alt='Joner Football Camp Highlight 2'><span>&#x25BA;</span></a>"
              src="https://www.youtube.com/embed/ZEAlkFIzVQc"
              title="Joner Football Camp Highlight"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full border border-gray-800"
            ></iframe>
          </div>
        </div>
        <div>
          <div class="relative w-full" style="aspect-ratio: 16/9;">
            <iframe
              srcdoc="<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%;background:#0a0a0a}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#fff;text-shadow:0 0 0.5em black}</style><a href=https://www.youtube.com/embed/oooWE3pAgm8?autoplay=1><img src=https://img.youtube.com/vi/oooWE3pAgm8/hqdefault.jpg alt='Joner Football Camp Highlight 3'><span>&#x25BA;</span></a>"
              src="https://www.youtube.com/embed/oooWE3pAgm8"
              title="Joner Football Camp Highlight"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full border border-gray-800"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Past camps gallery placeholder -->
  <section class="bg-joner-black py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Gallery</p>
        <h2 class="section-heading text-white">Past Camps</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[1,2,3,4,5,6,7,8].map((n) => (
          <div class="bg-joner-gray aspect-square overflow-hidden">
            <img src={`/images/camps/gallery-${n}.webp`} alt={`Joner Football training camp action photo ${n}`} class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <p class="text-gray-400 font-body">Based in Sydney? <a href="/training" class="text-joner-red hover:underline font-semibold">Train with us year-round →</a></p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="camps-notify" class="bg-joner-red py-12 md:py-16 scroll-mt-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading text-2xl md:text-4xl font-bold text-white uppercase mb-4">
        Don't Miss Out
      </h2>
      <p class="text-white/80 font-body mb-6">
        Camps sell out fast. Register your interest to be first in line.
      </p>
    </div>
  </section>

  <EmailCapture />

</BaseLayout>
