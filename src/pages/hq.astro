---
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'
---
<BaseLayout title="The Joner Football HQ | Belrose, Sydney" description="Brand new indoor training facility. 20 Narabang Way, Belrose. Home of JFP and Joners Juniors.">
  <section class="min-h-screen flex items-center justify-center bg-joner-black py-24">
    <div class="text-center px-4 max-w-2xl mx-auto">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-4">Belrose, Sydney</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-white uppercase mb-6">The HQ</h1>
      <p class="text-gray-400 font-body mb-8">Brand new indoor training facility. 20 Narabang Way, Belrose, 2085. Home of JFP afternoon sessions and Joners Juniors.</p>
      <p class="text-gray-500 font-body text-sm mb-8">Full HQ page — photos and facility details — coming soon.</p>
      <a href="/training" class="btn-red text-sm px-6 py-3">View Training Programs</a>
    </div>
  </section>
  <EmailCapture />
</BaseLayout>
