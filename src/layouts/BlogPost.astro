---
import BaseLayout from './BaseLayout.astro'
import EmailCapture from '../components/EmailCapture.astro'

export interface Props {
  title: string
  description: string
  date: string
  category: string
  readTime: string
  image?: string
  imageAlt?: string
}

const { title, description, date, category, readTime, image, imageAlt } = Astro.props

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "author": {
    "@type": "Organization",
    "name": "Joner Football"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Joner Football",
    "logo": { "@type": "ImageObject", "url": "https://jonerfootball.com/images/logo.png" }
  }
}
---

<BaseLayout
  title={`${title} | Joner Football Blog`}
  description={description}
  schema={articleSchema}
>
  <article class="bg-joner-black">
    <!-- Hero -->
    <div class="relative bg-joner-gray py-20 md:py-28">
      <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <div class="flex items-center justify-center gap-4 mb-4">
          <span class="bg-joner-red px-3 py-1 font-heading text-xs uppercase tracking-widest text-white">{category}</span>
          <span class="text-gray-500 text-sm font-body">{readTime}</span>
          <span class="text-gray-500 text-sm font-body">{date}</span>
        </div>
        <h1 class="font-heading text-3xl md:text-5xl font-bold text-white uppercase leading-tight">{title}</h1>
      </div>
    </div>

    {image && (
      <div class="max-w-4xl mx-auto px-4 -mt-8">
        <img src={image} alt={imageAlt || title} class="w-full aspect-video object-cover object-center" loading="eager" />
      </div>
    )}

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <div class="prose prose-invert prose-lg max-w-none
        [&_h2]:font-heading [&_h2]:text-white [&_h2]:uppercase [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:font-heading [&_h3]:text-white [&_h3]:uppercase [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-gray-300 [&_p]:font-body [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:space-y-2 [&_li]:text-gray-300 [&_li]:font-body
        [&_a]:text-joner-red [&_a]:hover:underline
        [&_strong]:text-white
        [&_ol]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6
        [&_ul]:list-disc [&_ul]:pl-6
      ">
        <slot />
      </div>
    </div>

    <!-- App CTA -->
    <section class="bg-joner-red py-12">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-white uppercase mb-3">
          Take Your Training Further
        </h2>
        <p class="text-white/80 font-body mb-6">
          For 1,500+ drills like these, download the Joner Football App.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://apps.apple.com/au/app/joner-football-app/id6737069275" target="_blank" rel="noopener" class="btn-outline border-white text-white hover:bg-white hover:text-joner-red px-6 py-3">
            Download on App Store
          </a>
          <a href="https://play.google.com/store/apps/details?id=tv.uscreen.jonerfootball" target="_blank" rel="noopener" class="btn-outline border-white text-white hover:bg-white hover:text-joner-red px-6 py-3">
            Get on Google Play
          </a>
        </div>
      </div>
    </section>
  </article>

  <EmailCapture />
</BaseLayout>
