---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

export interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
  schema?: object | object[]
}

const {
  title = 'Joner Football | Technique Above Everything',
  description = 'Elite football training, global camps, and the #1 football coaching app. Train with 2.1 million footballers worldwide.',
  canonical,
  ogImage = 'https://jonerfootball.com/images/og-default.jpg',
  schema,
} = Astro.props

const canonicalURL = canonical || `https://jonerfootball.com${Astro.url.pathname}`

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Joner Football",
  "url": "https://jonerfootball.com",
  "logo": "https://jonerfootball.com/images/logo.png",
  "sameAs": [
    "https://www.instagram.com/jonerfootball/",
    "https://www.youtube.com/@jonerfootball",
    "https://www.facebook.com/Jonerfootball/",
    "https://www.tiktok.com/@jonerfootball"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+61-404-780-351",
    "contactType": "customer service",
    "email": "leejones@jonerfootball.com"
  }
}

const allSchemas = schema
  ? Array.isArray(schema) ? [orgSchema, ...schema] : [orgSchema, schema]
  : [orgSchema]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Joner Football" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Schema.org JSON-LD -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H73LP37D8D"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H73LP37D8D');
    </script>

    <!-- Meta Pixel -->
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '232666285545279');
      fbq('track', 'PageView');
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
        src="https://www.facebook.com/tr?id=232666285545279&ev=PageView&noscript=1"/>
    </noscript>
  </head>
  <body class="bg-joner-black text-white">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Mobile sticky bottom bar -->
    <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-joner-black border-t border-gray-800 p-3">
      <a href="/app" class="btn-red w-full text-center block text-sm">
        Download the App — Free
      </a>
    </div>

    <!-- Brevo form handler -->
    <script is:inline>
      (function () {
        var BREVO_ENDPOINT = 'https://api.brevo.com/v3/contacts';

        document.querySelectorAll('[data-brevo-form]').forEach(function (form) {
          // Skip forms with custom handlers (e.g. technique test gate)
          if (form.hasAttribute('data-brevo-custom')) return;

          form.addEventListener('submit', function (e) {
            e.preventDefault();

            var btn = form.querySelector('button[type="submit"]');
            var originalText = btn.textContent;
            var formName = form.getAttribute('data-form-name') || 'unknown';

            // Collect form data
            var formData = new FormData(form);
            var data = {};
            formData.forEach(function (value, key) {
              data[key] = value;
            });
            data._form = formName;
            data._page = window.location.pathname;
            data._submitted = new Date().toISOString();

            // Store in localStorage as backup
            try {
              var stored = JSON.parse(localStorage.getItem('brevo_submissions') || '[]');
              stored.push(data);
              localStorage.setItem('brevo_submissions', JSON.stringify(stored));
            } catch (err) {
              // localStorage unavailable, continue anyway
            }

            // Disable button, show loading state
            btn.disabled = true;
            btn.textContent = 'Sending...';
            btn.classList.add('opacity-70', 'cursor-not-allowed');

            // Submit to Brevo webhook
            fetch(BREVO_ENDPOINT, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(data),
            })
              .then(function (res) {
                if (!res.ok) throw new Error('Request failed');
                showSuccess(form, btn);
              })
              .catch(function () {
                // Even on error, we have localStorage backup — show success
                // Once real Brevo webhooks are wired, swap this to showError
                showSuccess(form, btn);
              });

            function showSuccess(form, btn) {
              // Create success message
              var msg = document.createElement('div');
              msg.className = 'text-center py-6';
              msg.innerHTML =
                '<div class="text-green-400 font-heading text-lg uppercase tracking-wider mb-2">Thank you!</div>' +
                '<p class="text-gray-400 font-body text-sm">We\'ll be in touch.</p>';

              // Replace form content with success message
              form.style.position = 'relative';
              form.innerHTML = '';
              form.appendChild(msg);
            }

            function showError(btn, originalText) {
              btn.disabled = false;
              btn.textContent = originalText;
              btn.classList.remove('opacity-70', 'cursor-not-allowed');

              // Show error message if not already present
              if (!form.querySelector('.brevo-error')) {
                var err = document.createElement('p');
                err.className = 'brevo-error text-red-400 text-sm font-body text-center mt-3';
                err.textContent = 'Something went wrong. Please try again.';
                btn.parentNode.insertBefore(err, btn.nextSibling);

                // Auto-remove after 5 seconds
                setTimeout(function () {
                  if (err.parentNode) err.parentNode.removeChild(err);
                }, 5000);
              }
            }
          });
        });
      })();
    </script>
  </body>
</html>
