---
---

<section class="bg-joner-black border-t border-gray-800 py-16 md:py-24">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
    <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Free Training Videos</p>
    <h2 class="section-heading text-white mb-4">Get 10 Free Training Videos</h2>
    <p class="text-gray-400 font-body mb-8">
      Join 13,000+ footballers getting weekly tips
    </p>

    <form
      method="POST"
      action="https://api.brevo.com/v3/contacts"
      data-brevo-form
      data-form-name="email-capture"
      class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto"
    >
      <input
        type="text"
        name="first_name"
        placeholder="First name"
        required
        class="bg-joner-gray border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm flex-1 focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]"
      />
      <input
        type="email"
        name="email"
        placeholder="Email address"
        required
        class="bg-joner-gray border border-gray-700 text-white px-4 py-3 font-body text-base sm:text-sm flex-1 focus:outline-none focus:border-joner-red placeholder-gray-500 min-h-[44px]"
      />
      <button type="submit" class="btn-red text-sm px-6 py-3 whitespace-nowrap min-h-[44px]">
        Send Me The Videos
      </button>
    </form>

    <p class="text-gray-600 text-xs font-body mt-4">
      We respect your privacy. Unsubscribe anytime.
    </p>
  </div>
</section>
