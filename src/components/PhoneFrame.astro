---
export interface Props {
  videoSrc: string
  alt?: string
  class?: string
}

const { videoSrc, alt = "App preview", class: className = "" } = Astro.props
---

<div class:list={["relative inline-block", className]}>
  <!-- Phone outer shell -->
  <div class="relative w-full h-full bg-black border-[6px] border-gray-700 rounded-[2.5rem] overflow-hidden shadow-2xl">
    <!-- Notch -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-20 h-5 bg-black rounded-b-2xl z-10"></div>
    <!-- Video -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      aria-label={alt}
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
    <!-- Fallback gradient if video fails -->
    <div class="absolute inset-0 bg-gradient-to-b from-gray-900 to-black flex items-center justify-center" style="z-index:-1">
      <div class="text-center p-6">
        <div class="text-red-600 text-4xl mb-3">⚽</div>
        <div class="text-white text-sm font-bold">JONER FOOTBALL APP</div>
      </div>
    </div>
  </div>
</div>
