---
export interface Props {
  videoSrc: string
  alt?: string
  class?: string
}

const { videoSrc, alt = 'App preview', class: className = '' } = Astro.props
---

<div class:list={['phone-frame', className]}>
  <div class="bg-joner-black border-[6px] border-gray-700 rounded-[2.5rem] overflow-hidden shadow-2xl relative">
    <!-- Notch -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-6 bg-joner-black rounded-b-2xl z-10"></div>
    <!-- Video -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"
      aria-label={alt}
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
  </div>
</div>
