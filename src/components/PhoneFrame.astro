---
export interface Props {
  images?: string[]
  alt?: string
  class?: string
}

const {
  images = [
    "/images/app/screenshot-1.webp",
    "/images/app/screenshot-2.webp",
    "/images/app/screenshot-3.webp",
    "/images/app/screenshot-4.webp"
  ],
  alt = "App preview",
  class: className = ""
} = Astro.props
---

<div class:list={["relative", className]}>
  <div class="relative w-full h-full bg-black border-[6px] border-gray-700 rounded-[2.5rem] overflow-hidden shadow-2xl">
    <!-- Notch -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-20 h-5 bg-black rounded-b-2xl z-10"></div>
    <!-- Image carousel -->
    <div class="phone-carousel absolute inset-0">
      {images.map((src, i) => (
        <img
          src={src}
          alt={`${alt} ${i + 1}`}
          class={`phone-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${i === 0 ? "opacity-100" : "opacity-0"}`}
          data-index={i}
          loading={i === 0 ? "eager" : "lazy"}
        />
      ))}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll(".phone-carousel").forEach((carousel) => {
    const slides = carousel.querySelectorAll(".phone-slide");
    let current = 0;
    if (slides.length < 2) return;
    setInterval(() => {
      slides[current].classList.remove("opacity-100");
      slides[current].classList.add("opacity-0");
      current = (current + 1) % slides.length;
      slides[current].classList.remove("opacity-0");
      slides[current].classList.add("opacity-100");
    }, 3500);
  });
</script>
