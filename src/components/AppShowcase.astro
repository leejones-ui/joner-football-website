---
const features = [
  { icon: '🎯', label: '1,500+ Drills', desc: 'Every technique, every position' },
  { icon: '📄', label: 'Session Plans', desc: 'Ready to print PDFs for coaches' },
  { icon: '▶️', label: 'Follow-Along Programs', desc: 'Train with Coach Joner' },
  { icon: '🧠', label: 'Coaches Section', desc: 'Behind the scenes methodology' },
  { icon: '📡', label: 'Weekly Live Sessions', desc: 'Train live with Lee every week' },
  { icon: '👥', label: 'Team Subscriptions', desc: 'Train your whole squad' },
]
---

<section class="bg-joner-gray py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Phone mockup (placeholder) -->
      <div class="flex justify-center order-2 lg:order-1">
        <div class="relative">
          <div class="bg-joner-black border-4 border-gray-700 rounded-3xl w-64 h-[520px] flex items-center justify-center shadow-2xl">
            <div class="text-center px-6">
              <div class="text-6xl mb-4">📱</div>
              <p class="text-gray-400 text-sm font-body">App screenshot<br/>coming soon</p>
              <div class="mt-6 space-y-2">
                <div class="bg-joner-red h-2 rounded w-full"></div>
                <div class="bg-gray-700 h-2 rounded w-3/4"></div>
                <div class="bg-gray-700 h-2 rounded w-1/2"></div>
              </div>
            </div>
          </div>
          <!-- Red glow effect -->
          <div class="absolute -inset-4 bg-joner-red/10 rounded-3xl blur-xl -z-10"></div>
        </div>
      </div>

      <!-- Content -->
      <div class="order-1 lg:order-2">
        <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The App</p>
        <h2 class="section-heading text-white mb-6">Your Complete<br/>Training Platform</h2>
        <p class="text-gray-400 font-body mb-8 leading-relaxed">
          Everything you need to take your game to the next level. Used by 50,000+ players and coaches worldwide.
        </p>

        <!-- Feature grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          {features.map((f) => (
            <div class="flex items-start gap-3">
              <span class="text-xl flex-shrink-0">{f.icon}</span>
              <div>
                <div class="font-heading text-white font-semibold text-sm">{f.label}</div>
                <div class="text-gray-500 text-xs font-body mt-0.5">{f.desc}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <a href="https://apps.apple.com/app/joner-football" target="_blank" rel="noopener"
            class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div>
              <div class="text-white text-xs leading-none">Download on the</div>
              <div class="text-white font-semibold text-sm">App Store</div>
            </div>
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.jonerfootball" target="_blank" rel="noopener"
            class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.4.6 1.2 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/></svg>
            <div>
              <div class="text-white text-xs leading-none">Get it on</div>
              <div class="text-white font-semibold text-sm">Google Play</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
