---
const features = [
  { icon: '🎯', label: '1,500+ Drills', desc: 'Every technique, every position' },
  { icon: '📄', label: 'Session Plans', desc: 'Ready to print PDFs for coaches' },
  { icon: '▶️', label: 'Follow-Along Programs', desc: 'Train with Coach Joner' },
  { icon: '🧠', label: 'Coaches Section', desc: 'Behind the scenes methodology' },
  { icon: '📡', label: 'Weekly Live Sessions', desc: 'Train live with Lee every week' },
  { icon: '👥', label: 'Team Subscriptions', desc: 'Train your whole squad' },
]

const screenshots = [
  { src: '/images/app/screenshot-1.webp', alt: 'Joner Football App home screen with training categories', rotate: '-6deg', z: 10, offsetY: '12px' },
  { src: '/images/app/screenshot-2.webp', alt: 'Joner Football App showing session plans and drills', rotate: '-2deg', z: 20, offsetY: '0px' },
  { src: '/images/app/screenshot-3.webp', alt: 'Joner Football App follow-along training program', rotate: '2deg', z: 30, offsetY: '4px' },
  { src: '/images/app/screenshot-4.webp', alt: 'Joner Football App live sessions and coaching content', rotate: '6deg', z: 20, offsetY: '10px' },
]
---

<section class="bg-joner-gray py-16 md:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12 md:mb-16">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">The App</p>
      <h2 class="section-heading text-white mb-4">Your Complete<br/>Training Platform</h2>
      <p class="text-gray-400 font-body max-w-2xl mx-auto leading-relaxed">
        Everything you need to take your game to the next level. Used by 50,000+ players and coaches worldwide.
      </p>
    </div>

    <!-- Phone mockups - fanned out row -->
    <div class="relative flex justify-center items-center mb-12 md:mb-16">
      <!-- Red glow behind phones -->
      <div class="absolute w-[80%] h-[60%] bg-joner-red/10 rounded-full blur-3xl -z-0"></div>

      <!-- Desktop: overlapping fan | Mobile: horizontal scroll -->
      <div class="hidden md:flex justify-center items-end -space-x-10 lg:-space-x-8">
        {screenshots.map((s) => (
          <div
            class="relative flex-shrink-0 transition-transform duration-300 hover:scale-105 hover:!rotate-0"
            style={`transform: rotate(${s.rotate}) translateY(${s.offsetY}); z-index: ${s.z};`}
          >
            <!-- Phone frame -->
            <div class="w-48 lg:w-56 rounded-[2rem] border-[5px] border-gray-800 bg-joner-black shadow-2xl overflow-hidden">
              <!-- Notch / status bar -->
              <div class="bg-joner-black flex justify-center pt-2 pb-1">
                <div class="w-16 h-1.5 bg-gray-800 rounded-full"></div>
              </div>
              <!-- Screenshot -->
              <div class="aspect-[9/17]">
                <img
                  src={s.src}
                  alt={s.alt}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                />
              </div>
              <!-- Bottom bar -->
              <div class="bg-joner-black flex justify-center py-1.5">
                <div class="w-10 h-1 bg-gray-700 rounded-full"></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Mobile: horizontal scroll -->
      <div class="flex md:hidden gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scroll-px-4 -mx-4 px-4 no-scrollbar">
        {screenshots.map((s) => (
          <div class="flex-shrink-0 snap-center">
            <div class="w-40 sm:w-48 rounded-[2rem] border-[5px] border-gray-800 bg-joner-black shadow-2xl overflow-hidden">
              <div class="bg-joner-black flex justify-center pt-2 pb-1">
                <div class="w-16 h-1.5 bg-gray-800 rounded-full"></div>
              </div>
              <div class="aspect-[9/17]">
                <img
                  src={s.src}
                  alt={s.alt}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                />
              </div>
              <div class="bg-joner-black flex justify-center py-1.5">
                <div class="w-10 h-1 bg-gray-700 rounded-full"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Features + CTA -->
    <div class="max-w-4xl mx-auto">
      <!-- Feature grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4 mb-10">
        {features.map((f) => (
          <div class="flex items-start gap-2 sm:gap-3 bg-joner-black/50 rounded-xl p-3 border border-gray-800/50">
            <span class="text-lg sm:text-xl flex-shrink-0">{f.icon}</span>
            <div>
              <div class="font-heading text-white font-semibold text-sm">{f.label}</div>
              <div class="text-gray-500 text-xs font-body mt-0.5">{f.desc}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <a href="https://jonerfootball.com/join/" class="btn-red">
          Start Free Trial
        </a>
        <a href="https://apps.apple.com/au/app/joner-football-app/id6737069275" target="_blank" rel="noopener"
          class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <div>
            <div class="text-white text-xs leading-none">Download on the</div>
            <div class="text-white font-semibold text-sm">App Store</div>
          </div>
        </a>
        <a href="https://play.google.com/store/apps/details?id=tv.uscreen.jonerfootball" target="_blank" rel="noopener"
          class="bg-black border border-gray-700 rounded-lg px-4 py-2 flex items-center gap-3 hover:border-white transition-colors">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.4.6 1.2 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/></svg>
          <div>
            <div class="text-white text-xs leading-none">Get it on</div>
            <div class="text-white font-semibold text-sm">Google Play</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
