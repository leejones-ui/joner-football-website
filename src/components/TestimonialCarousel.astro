---
const testimonials = [
  {
    quote: "Best football training my son has ever experienced. The improvement in 10 weeks was unreal.",
    name: "Sarah M.",
    role: "Parent",
    location: "Sydney, Australia",
  },
  {
    quote: "The session plans alone are worth the subscription. Changed how I run my academy.",
    name: "Coach Dave R.",
    role: "Coach",
    location: "California, USA",
  },
  {
    quote: "Joner's drills are different to anything else out there. You can feel the improvement.",
    name: "Tom K.",
    role: "Player",
    location: "Melbourne, Australia",
  },
]
---

<section class="bg-joner-gray py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-joner-red font-heading text-sm uppercase tracking-widest mb-3">Testimonials</p>
      <h2 class="section-heading text-white">What They Say</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="border border-gray-700 p-8 relative">
          <div class="text-joner-red text-5xl font-heading leading-none mb-4">"</div>
          <p class="text-gray-300 font-body text-base leading-relaxed mb-6 italic">{t.quote}</p>
          <div class="border-t border-gray-700 pt-4">
            <div class="font-heading text-white font-semibold">{t.name}</div>
            <div class="text-joner-red text-xs font-heading uppercase tracking-wide">{t.role}</div>
            <div class="text-gray-500 text-xs font-body mt-0.5">{t.location}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
