---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <img src="/images/homepage/hero-bg.webp" alt="Joner Football training session in action" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-joner-black/80 via-joner-black/60 to-joner-black/90"></div>
  </div>

  <!-- Red accent line at top -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-joner-red"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 sm:px-6 max-w-5xl mx-auto">
    <p class="text-joner-red font-heading text-sm md:text-base uppercase tracking-widest mb-4 font-semibold">
      2.1 Million Footballers Worldwide
    </p>
    <h1 class="font-heading text-5xl sm:text-7xl lg:text-9xl font-bold text-white uppercase leading-none tracking-tight mb-6">
      TECHNIQUE<br/>
      <span class="text-joner-red">ABOVE</span><br/>
      EVERYTHING
    </h1>
    <p class="text-gray-300 text-lg md:text-xl mb-10 max-w-xl mx-auto font-body font-light">
      Train with Coach Joner. Elite drills, global camps, and the world's best football coaching app.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/app" class="btn-red text-base px-8 py-4 w-full sm:w-auto text-center">
        Start Training Free
      </a>
      <a href="/camps" class="btn-outline text-base px-8 py-4 w-full sm:w-auto text-center">
        Book a Camp
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
